# syntax=docker/dockerfile:1@sha256:87999aa3d42bdc6bea60565083ee17e86d1f3339802f543c0d03998580f9cb89

ARG BLUEFIN_BASE_IMAGE=ghcr.io/ublue-os/bluefin-nvidia-open:stable@sha256:1e7a59c83f104652bd06308f0a6439669cb3ea327d4e968695af85c67abea352
ARG BLUEFIN_BASE_IMAGE_NAME=bluefin-nvidia-open
ARG BLUEFIN_BASE_IMAGE_TAG=stable

FROM ghcr.io/astral-sh/uv:0.11.29@sha256:eb2843a1e56fd9e30c7276ce1a52cba86e64c7b385f5e3279a0e08e02dd058fc AS uv

FROM docker.io/library/debian:bookworm-slim@sha256:7b140f374b289a7c2befc338f42ebe6441b7ea838a042bbd5acbfca6ec875818 AS nix-tools

ARG DETERMINATE_NIX_INSTALLER_VERSION=v3.21.5
ADD --chmod=0755 \
    https://install.determinate.systems/nix/tag/${DETERMINATE_NIX_INSTALLER_VERSION}/nix-installer-x86_64-linux \
    /tmp/nix-installer
RUN printf '%s  %s\n' \
    'ee9c560d6f093baf7a8b342d8a00e9f8b47dd4a6367f3f523482ee96897c4179' \
    /tmp/nix-installer | sha256sum --check - && \
    /tmp/nix-installer install linux \
    --extra-conf 'sandbox = false' \
    --init none \
    --no-confirm && \
    rm /tmp/nix-installer

ENV PATH="/nix/var/nix/profiles/default/bin:${PATH}"

COPY spectrum/nix-tools /src
WORKDIR /src
RUN nix build \
    --out-link /tmp/spectrum-nix-tools \
    .#bundle && \
    cp --dereference /tmp/spectrum-nix-tools /spectrum-nix-tools

FROM scratch AS ctx
COPY ansible/files/scripts/workstation /image/ansible/files/scripts/workstation
COPY patches /image/patches
COPY spectrum/image/repos /image/spectrum/image/repos
COPY spectrum/scripts /image/spectrum/scripts
COPY pyproject.toml uv.lock /image/

FROM scratch AS rootfs
COPY spectrum/image/rootfs /

FROM ${BLUEFIN_BASE_IMAGE}

ARG BLUEFIN_BASE_IMAGE
ARG BLUEFIN_BASE_IMAGE_NAME
ARG BLUEFIN_BASE_IMAGE_TAG
ARG IMAGE_NAME="spectrum"
ARG IMAGE_VENDOR="4evy"
ARG IMAGE_TAG="latest"
ARG IMAGE_REF="ostree-image:docker://ghcr.io/4evy/spectrum"
ARG IMAGE_REVISION
ARG IMAGE_VERSION

# bootc lint needs the marker while validating the filesystem. Keep volatile OCI
# provenance labels until the end so a new build timestamp cannot bust this layer.
LABEL containers.bootc=1

# Fedora composefs images cannot create new root-level mountpoints at runtime.
# Keep /nix non-empty so it survives the image-to-ostree deployment path.
RUN rm -rf /opt && mkdir /opt /nix && touch /nix/.spectrum-mountpoint

# Fedora's uv package can lag behind the minimum version required by the project.
COPY --from=uv /uv /usr/bin/uv
COPY --from=nix-tools /spectrum-nix-tools /usr/libexec/spectrum-nix-tools

RUN --mount=type=bind,from=ctx,source=/image,target=/ctx \
    --mount=type=cache,id=spectrum-dnf5,sharing=locked,target=/var/cache/libdnf5 \
    --mount=type=cache,id=spectrum-uv,sharing=locked,target=/var/cache/uv \
    --mount=type=tmpfs,target=/boot \
    --mount=type=tmpfs,target=/var/log \
    --mount=type=tmpfs,target=/run \
    --mount=type=tmpfs,target=/tmp \
    --mount=type=secret,id=github_token,required=false \
    mkdir -p /var/roothome && \
    cp -a /ctx /tmp/spectrum-src && \
    GITHUB_TOKEN="$(cat /run/secrets/github_token 2>/dev/null || true)" \
    BLUEFIN_BASE_IMAGE="${BLUEFIN_BASE_IMAGE}" \
    BLUEFIN_BASE_IMAGE_NAME="${BLUEFIN_BASE_IMAGE_NAME}" \
    BLUEFIN_BASE_IMAGE_TAG="${BLUEFIN_BASE_IMAGE_TAG}" \
    IMAGE_NAME="${IMAGE_NAME}" \
    IMAGE_VENDOR="${IMAGE_VENDOR}" \
    IMAGE_TAG="${IMAGE_TAG}" \
    IMAGE_REF="${IMAGE_REF}" \
    IMAGE_REVISION="${IMAGE_REVISION}" \
    IMAGE_VERSION="${IMAGE_VERSION}" \
    UV_CACHE_DIR=/var/cache/uv \
    UV_LINK_MODE=copy \
    UV_PROJECT_ENVIRONMENT=/tmp/spectrum-build-venv \
    python3 /tmp/spectrum-src/spectrum/scripts/build.py

# Cache mount targets can leave empty /var directories behind in the final image;
# bootc lint treats those as fatal unless tmpfiles rules own them.
RUN rm -rf /var/cache/dnf /var/cache/libdnf5 /var/cache/uv

# Keep the static overlay separate from the expensive package/program layer.
# Copy it last so Spectrum-owned configuration wins over files installed by RPMs.
COPY --from=rootfs / /

CMD ["/sbin/init"]

RUN test -x /usr/bin/open && \
    test -x /usr/libexec/spectrum-nix-tools && \
    for command in deadnix nil nixd nixfmt; do \
        command -v "${command}" >/dev/null; \
    done && \
    bootc container lint --fatal-warnings

# Presentation metadata does not affect the filesystem. Keep it last so changes
# to documentation URLs and descriptions cannot bust validated filesystem layers.
ARG IMAGE_TITLE="spectrum"
ARG IMAGE_DESCRIPTION="Spectrum Bluefin image for dotfiles"
ARG IMAGE_AUTHORS="4evy <git@evy.pink>"
ARG IMAGE_SOURCE="https://github.com/4evy/dotfiles"
ARG IMAGE_URL="https://github.com/4evy/dotfiles"
ARG IMAGE_DOCUMENTATION="https://github.com/4evy/dotfiles#readme"
ARG IMAGE_README="https://raw.githubusercontent.com/4evy/dotfiles/master/README.md"
ARG IMAGE_LOGO="https://avatars.githubusercontent.com/u/57304299?v=4"
ARG IMAGE_LICENSES="MIT"

LABEL org.opencontainers.image.title="${IMAGE_TITLE}" \
      org.opencontainers.image.description="${IMAGE_DESCRIPTION}" \
      org.opencontainers.image.authors="${IMAGE_AUTHORS}" \
      org.opencontainers.image.source="${IMAGE_SOURCE}" \
      org.opencontainers.image.url="${IMAGE_URL}" \
      org.opencontainers.image.documentation="${IMAGE_DOCUMENTATION}" \
      org.opencontainers.image.licenses="${IMAGE_LICENSES}" \
      org.opencontainers.image.revision="${IMAGE_REVISION}" \
      org.opencontainers.image.version="${IMAGE_VERSION}" \
      org.opencontainers.image.vendor="${IMAGE_VENDOR}" \
      org.opencontainers.image.license="${IMAGE_LICENSES}" \
      io.artifacthub.package.deprecated=false \
      io.artifacthub.package.keywords="bootc,bluefin,ublue,spectrum,dotfiles" \
      io.artifacthub.package.license="${IMAGE_LICENSES}" \
      io.artifacthub.package.logo-url="${IMAGE_LOGO}" \
      io.artifacthub.package.maintainers="[{\"name\":\"4evy\",\"email\":\"git@evy.pink\"}]" \
      io.artifacthub.package.readme-url="${IMAGE_README}" \
      io.artifacthub.package.prerelease=false
