{{- if lookPath "lldb-mcp-launcher" }}
[mcp_servers.lldb]
command = "lldb-mcp-launcher"
enabled = false
startup_timeout_sec = 30
tool_timeout_sec = 1800
default_tools_approval_mode = "approve"
enabled_tools = [
  "command",
  "debugger_list",
]
{{- end }}

{{- if eq .chezmoi.os "darwin" }}
{{- $codexAppRoot := "/Applications/Codex.app" }}
{{- $codexContentsRoot := joinPath $codexAppRoot "Contents" }}
{{- $codexResourceRoot := joinPath $codexContentsRoot "Resources" }}
{{- $browserClientPath := joinPath $codexResourceRoot "plugins/openai-bundled/plugins/browser/scripts/browser-client.mjs" }}
{{- $codexInfoPlistPath := joinPath $codexContentsRoot "Info.plist" }}
{{- $browserClientSha := "" }}
{{- if and (stat $browserClientPath) (lookPath "shasum") }}
{{- $browserClientSha = (output "shasum" "-a" "256" $browserClientPath | regexFind "^[0-9a-f]+") }}
{{- end }}
{{- $codexAppVersion := "" }}
{{- if and (stat $codexInfoPlistPath) (lookPath "awk") }}
{{- $codexAppVersion = (output "awk" "/<key>CFBundleShortVersionString<\\/key>/{getline; gsub(/.*<string>|<\\/string>.*/, \"\"); print; exit}" $codexInfoPlistPath | trim) }}
{{- end }}
{{- $nodeReplCommand := lookPath (joinPath $codexResourceRoot "cua_node/bin/node_repl") }}
{{- $nodePath := joinPath $codexResourceRoot "cua_node/bin/node" }}
{{- if not $nodeReplCommand }}
{{- $nodeReplCommand = lookPath (joinPath $codexResourceRoot "node_repl") }}
{{- $nodePath = joinPath $codexResourceRoot "node" }}
{{- end }}
{{- if $nodeReplCommand }}
[mcp_servers.node_repl]
args = []
command = "{{ $nodeReplCommand }}"
startup_timeout_sec = 120
default_tools_approval_mode = "approve"

[mcp_servers.node_repl.env]
NODE_REPL_NATIVE_PIPE_CONNECT_TIMEOUT_MS = "1000"
NODE_REPL_NODE_MODULE_DIRS = ""
NODE_REPL_NODE_PATH = "{{ $nodePath }}"
NODE_REPL_TRUSTED_CODE_PATHS = "{{ .chezmoi.homeDir }}/.codex"
CODEX_HOME = "{{ .chezmoi.homeDir }}/.codex"
{{- if $browserClientSha }}
NODE_REPL_TRUSTED_BROWSER_CLIENT_SHA256S = "{{ $browserClientSha }}"
{{- end }}
BROWSER_USE_AVAILABLE_BACKENDS = "iab,chrome"
NODE_REPL_INSTRUCTIONS_USE_CASE_BROWSER = "Control the in-app browser in conjunction with the Browser Plugin."
BROWSER_USE_CODEX_APP_BUILD_FLAVOR = "prod"
{{- if $codexAppVersion }}
BROWSER_USE_CODEX_APP_VERSION = "{{ $codexAppVersion }}"
{{- end }}
CODEX_CLI_PATH = "/Applications/Codex.app/Contents/Resources/codex"

[marketplaces.openai-bundled]
source_type = "local"
source = "{{ .chezmoi.homeDir }}/.codex/.tmp/bundled-marketplaces/openai-bundled"

[plugins."browser@openai-bundled"]
enabled = true

[plugins."chrome@openai-bundled"]
enabled = true

[plugins."computer-use@openai-bundled"]
enabled = true
{{- end }}
{{- end }}

[apps._default]
enabled = true
destructive_enabled = true
open_world_enabled = true
default_tools_approval_mode = "approve"

[notice]
hide_full_access_warning = true
hide_world_writable_warning = true

[desktop]
appearanceLightCodeThemeId = "catppuccin"
appearanceDarkCodeThemeId = "catppuccin"

[desktop.appearanceLightChromeTheme]
accent = "{{ index $latte "pink" }}"
contrast = 45
ink = "{{ index $latte "text" }}"
opaqueWindows = false
surface = "{{ index $latte "base" }}"

[desktop.appearanceLightChromeTheme.fonts]

[desktop.appearanceLightChromeTheme.semanticColors]
diffAdded = "{{ index $latte "green" }}"
diffAddedBg = "{{ $latteDiffAddedBg }}"
diffRemoved = "{{ index $latte "red" }}"
diffRemovedBg = "{{ $latteDiffRemovedBg }}"
skill = "{{ index $latte "mauve" }}"

[desktop.appearanceDarkChromeTheme]
accent = "{{ index $frappe "pink" }}"
contrast = 60
ink = "{{ index $frappe "text" }}"
opaqueWindows = false
surface = "{{ index $frappe "base" }}"

[desktop.appearanceDarkChromeTheme.fonts]

[desktop.appearanceDarkChromeTheme.semanticColors]
diffAdded = "{{ index $frappe "green" }}"
diffAddedBg = "{{ $frappeDiffAddedBg }}"
diffRemoved = "{{ index $frappe "red" }}"
diffRemovedBg = "{{ $frappeDiffRemovedBg }}"
skill = "{{ index $frappe "mauve" }}"
