# PATH
# Prepend preferred tools while retaining the inherited order.
{{- $isNixOS := false }}
{{- if eq .chezmoi.os "linux" }}
{{- $isNixOS = eq .chezmoi.osRelease.id "nixos" }}
{{- end }}

_dotfiles_path_prepend_once() {
	local -a current_path=() new_path=()
	local dir

	_dotfiles_path_append_once() {
		local candidate existing
		for candidate; do
			[[ -n "$candidate" ]] || continue
			for existing in "${new_path[@]}"; do
				[[ "$existing" == "$candidate" ]] && continue 2
			done
			new_path+=("$candidate")
		done
	}

	_dotfiles_path_append_once "$@"

	local IFS=:
	read -r -a current_path <<<"${PATH:-}"
	for dir in "${current_path[@]}"; do
		_dotfiles_path_append_once "$dir"
	done

	PATH="${new_path[*]}"
	unset -f _dotfiles_path_append_once
}

_dotfiles_path_entries=(
	{{- if not $isNixOS }}
	"$HOME/.pi/agent/bin"
	"$HOME/.local/share/dotfiles/helix-tip/bin"
	{{- if eq .chezmoi.os "darwin" }}
	{{- if eq .chezmoi.arch "arm64" }}
	/opt/homebrew/opt/coreutils/libexec/gnubin
	/opt/homebrew/opt/findutils/libexec/gnubin
	/opt/homebrew/opt/gnu-sed/libexec/gnubin
	/opt/homebrew/opt/grep/libexec/gnubin
	/opt/homebrew/opt/gawk/libexec/gnubin
	/opt/homebrew/opt/gnu-tar/libexec/gnubin
	/opt/homebrew/opt/gnu-which/libexec/gnubin
	/opt/homebrew/opt/diffutils/libexec/gnubin
	/opt/homebrew/opt/make/libexec/gnubin
	/opt/homebrew/opt/gnu-getopt/bin
	/opt/homebrew/bin
	/opt/homebrew/sbin
	{{- else }}
	/usr/local/opt/coreutils/libexec/gnubin
	/usr/local/opt/findutils/libexec/gnubin
	/usr/local/opt/gnu-sed/libexec/gnubin
	/usr/local/opt/grep/libexec/gnubin
	/usr/local/opt/gawk/libexec/gnubin
	/usr/local/opt/gnu-tar/libexec/gnubin
	/usr/local/opt/gnu-which/libexec/gnubin
	/usr/local/opt/diffutils/libexec/gnubin
	/usr/local/opt/make/libexec/gnubin
	/usr/local/opt/gnu-getopt/bin
	/usr/local/bin
	/usr/local/sbin
	{{- end }}
	{{- end }}
	"$HOME/.local/bin"
	"$HOME/.bun/bin"
	"$HOME/.bun/install/global/node_modules/.bin"
	"$HOME/.cache/.bun/bin"
	"$HOME/.npm/bin"
	"$HOME/.cargo/bin"
	"$HOME/.go/bin"
	"$HOME/.yarn/bin"
	{{- end }}
	{{- if eq .chezmoi.os "linux" }}
	{{- if not $isNixOS }}
	"$HOME/.nix-profile/bin"
	/nix/var/nix/profiles/default/bin
	{{- end }}
	/usr/local/bin
	/usr/bin
	/bin
	/usr/sbin
	/sbin
	{{- else if and (eq .chezmoi.os "darwin") (eq .chezmoi.arch "arm64") }}
	/usr/local/bin
	/usr/local/sbin
	{{- end }}
)
_dotfiles_path_prepend_once "${_dotfiles_path_entries[@]}"
unset _dotfiles_path_entries

# NixOS wrappers
# Prefer privileged wrapper binaries where NixOS provides them.

if [[ -d /run/wrappers/bin ]]; then
	_dotfiles_path_prepend_once /run/wrappers/bin
fi

unset -f _dotfiles_path_prepend_once
export PATH

# Shared environment
# Load Homebrew metadata, the SSH agent, and shared defaults.

if [[ -r "$HOME/.config/shell/environment.sh" ]]; then
	# shellcheck source=/dev/null
	source "$HOME/.config/shell/environment.sh"
fi
