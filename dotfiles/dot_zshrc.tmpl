# zsh / interactive setup
#   вЈҖвЈҖ вўҖвЈҖ вЈҮвЎҖ   вўҖвЈҖ вўҖвЎҖ вЈҖвЎҖ вўҖвЈҖ вўҖвЎҖ вЎҖ   вўҖвЎҖ
#   в ҙв Ҙ в ӯв • в Үв ё   в Јв Ө в Јв ң в Үв ё в ӯв • в Јв ң в §в Ө в Јв ӯ
#
#      в•ӯв”Җв”Җв”Җв”Җ A / TERM + Ghostty в”Җв”Җв”Җв”Җв”Җв”Җв•®
#      в”Ӯ Ghostty / TERM               в”Ӯ
#      в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ
#                      в–ј
#      в•ӯв”Җв”Җв”Җв”Җ B / plugins + prompt в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
#      в”Ӯ OMZ вҶ’ highlight вҶ’ fzf-tab вҶ’ Starship вҶ’ Atuin         в”Ӯ
#      в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ
#                      в–ј
#      в•ӯв”Җв”Җв”Җв”Җ C / shared commands в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
#      в”Ӯ shared commands вҶ’ zoxide owns cd вҶ’ fzf-tab         в”Ӯ
#      в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ
#
# Prefer cached init scripts; generate them directly on a fresh install.

#  /"\/\_..--------------------._/\/"\
# (     _|| A1 TERM + GHOSTTY  ||_     )
#  \_/\/ || Ghostty + fallback || \/\_/
#        || shell integration  ||
#  /"\/\_|---------------------|_/\/"\
# (     _|                     |_     )
#  \_/\/ `---------------------' \/\_/
if [[ "${TERM:-}" == "xterm-ghostty" ]] && ! infocmp xterm-ghostty &>/dev/null; then
  export TERM=xterm-256color
fi

if [[ -n "${GHOSTTY_RESOURCES_DIR:-}" ]] \
  && [[ -r "${GHOSTTY_RESOURCES_DIR}/shell-integration/zsh/ghostty-integration" ]]; then
  source "${GHOSTTY_RESOURCES_DIR}/shell-integration/zsh/ghostty-integration"
fi

# A2 / startup helpers
# Resolve binaries before generated init scripts replace command names.

_dotfiles_wrap_command() {
  emulate -L zsh
  local -r command_name=$1
  local -r command_path=$2
  eval "$command_name() { command ${(q)command_path} \"\$@\"; }"
}

# A3 / dotfiles repository
# DOTFILES_REPO takes priority. macOS also checks ~/Developer/dotfiles before
# falling back to ~/dotfiles.

_dotfiles_repo_path="${DOTFILES_REPO:-}"
if [[ -z "$_dotfiles_repo_path" ]]; then
  case "$(uname -s 2>/dev/null)" in
    Darwin)
      _dotfiles_repo_candidates=("$HOME/Developer/dotfiles" "$HOME/dotfiles")
      ;;
    *)
      _dotfiles_repo_candidates=("$HOME/dotfiles")
      ;;
  esac
  for _dotfiles_repo_candidate in "${_dotfiles_repo_candidates[@]}"; do
    [[ -f "$_dotfiles_repo_candidate/Justfile" ]] || continue
    [[ -d "$_dotfiles_repo_candidate/ansible" ]] || continue
    _dotfiles_repo_path="$_dotfiles_repo_candidate"
    break
  done
fi
if [[ -z "$_dotfiles_repo_path" ]]; then
  _dotfiles_repo_path="$HOME/dotfiles"
fi
if [[ -d "$_dotfiles_repo_path" ]]; then
  _dotfiles_repo_path="$(
    cd -P -- "$_dotfiles_repo_path" 2>/dev/null &&
      pwd ||
      printf '%s\n' "$_dotfiles_repo_path"
  )"
fi
unset _dotfiles_repo_candidate _dotfiles_repo_candidates

_dotfiles_command_path() {
  emulate -L zsh
  (( $+commands[$1] )) || return 1
  print -r -- "$commands[$1]"
}

# A4 / Ansible fallback
# Use uvx when ansible-playbook is not installed yet.

_dotfiles_ansible_playbook() {
  emulate -L zsh
  if command -v ansible-playbook >/dev/null 2>&1; then
    ansible-playbook "$@"
  elif command -v uvx >/dev/null 2>&1; then
    uvx --from ansible-core ansible-playbook "$@"
  else
    print -u2 "ansible-playbook and uvx are not available"
    return 127
  fi
}

#      __^__                         __^__
#     ( ___ )в”Җв”Җв”Җв”Җ B1 PLUGINS в”Җв”Җв”Җв”Җв”Җв”Җв”Җ( ___ )
#      | / |                         | \ |
#      | / | Oh My Zsh + plugins     | \ |
#      | / | fzf-tab keeps Tab       | \ |
#      | / | highlighting first      | \ |
#      |___|                         |___|
#     (_____)в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ(_____)
# Starship owns the prompt; Atuin waits for a real TTY.
export ZSH="$HOME/.oh-my-zsh"
# shellcheck disable=SC2034
ZSH_THEME=""
# shellcheck disable=SC2034
DISABLE_AUTO_UPDATE="true"
# shellcheck disable=SC2034
DISABLE_UNTRACKED_FILES_DIRTY="true"

# Keep the plugin list explicit.
plugins=(
  git
  rust
  nmap
  rsync
  colored-man-pages
  sudo
  extract
  copypath
  copyfile
  fzf-tab
  zsh-autosuggestions
  zsh-syntax-highlighting
)
if _dotfiles_command_path gh >/dev/null; then
  plugins+=(gh)
fi

# Make cached completions available before compinit.
fpath=("$HOME/.cache/zsh/completions" "${fpath[@]}")

# The highlighting plugin reads this palette when Oh My Zsh loads it.

if [[ -r "$HOME/.config/shell/zsh-syntax-highlighting.zsh" ]]; then
  # shellcheck source=/dev/null
  source "$HOME/.config/shell/zsh-syntax-highlighting.zsh"
fi

if [[ -r "$ZSH/oh-my-zsh.sh" ]]; then
  # shellcheck source=/dev/null
  source "$ZSH/oh-my-zsh.sh"
fi

# B2 / terminal focus events
# Bind focus-in and focus-out escape sequences to a no-op widget.

_dotfiles_disable_terminal_focus_reporting() {
  emulate -L zsh
  [[ -t 1 ]] || return 0
  print -rn -- $'\e[?1004l' >/dev/tty 2>/dev/null || true
}

_dotfiles_ignore_terminal_focus_event() {}
zle -N _dotfiles_ignore_terminal_focus_event
bindkey $'\e[I' _dotfiles_ignore_terminal_focus_event
bindkey $'\e[O' _dotfiles_ignore_terminal_focus_event

# B3 / completions, prompt, and history
# fzf leaves Tab to fzf-tab. Starship and Atuin use cached init scripts when
# available; Atuin only loads on a real terminal.

# Load fzf's key bindings without letting its completion widget steal Tab from
# fzf-tab.
_fzf_init() {
  emulate -L zsh
  # Keep fzf completion/history support, but do not bind its file picker to
  # Ctrl-T. An explicitly empty value is fzf's supported opt-out.
  local FZF_CTRL_T_COMMAND=''
  local fzf_bin
  fzf_bin="$(_dotfiles_command_path fzf)" || return
  _dotfiles_wrap_command fzf "$fzf_bin"

  local init
  if [[ -r "$HOME/.cache/fzf/init.zsh" ]]; then
    # shellcheck source=/dev/null
    source "$HOME/.cache/fzf/init.zsh"
    return
  fi

  init="$(
    "$fzf_bin" --zsh | sed \
      -e '/^### completion\.zsh ###$/,$d' \
      -e '/^  eval \$__fzf_key_bindings_options$/i\
  __fzf_key_bindings_options=${__fzf_key_bindings_options/ zle on/}\
  __fzf_key_bindings_options=${__fzf_key_bindings_options/ zle off/}'
  )" || return

  eval "$init"
}
_fzf_init
unset -f _fzf_init

zstyle ':completion:*' menu no
zstyle ':completion:*:*:*:*:*' menu no
zstyle ':completion:*:descriptions' format '[%d]'
zstyle ':completion:*' group-name ''
zstyle ':fzf-tab:*' switch-group '<' '>'

# Cached init files are generated by chezmoi; direct command init is the
# fresh-machine fallback.
_starship_bin="$(_dotfiles_command_path starship 2>/dev/null || true)"
if [[ -n "$_starship_bin" ]]; then
  _dotfiles_wrap_command starship "$_starship_bin"
fi
if [[ -n "$_starship_bin" && -r "$HOME/.cache/starship/init.zsh" ]]; then
  # shellcheck source=/dev/null
  source "$HOME/.cache/starship/init.zsh"
elif [[ -n "$_starship_bin" ]]; then
  eval "$("$_starship_bin" init zsh)"
fi
unset _starship_bin
_atuin_bin="$(_dotfiles_command_path atuin 2>/dev/null || true)"
if [[ -t 0 && -t 1 && -n "$_atuin_bin" && -r "$HOME/.cache/atuin/init.zsh" ]]; then
  _dotfiles_wrap_command atuin "$_atuin_bin"
  # shellcheck source=/dev/null
  source "$HOME/.cache/atuin/init.zsh"
  _atuin_search() {
    emulate -L zsh
    zle -I

    local output result_file __atuin_status
    result_file="$(mktemp)" || return 1
    # shellcheck disable=SC2153
    {
      ATUIN_SHELL=zsh \
        ATUIN_LOG=error \
        ATUIN_QUERY=$BUFFER \
        atuin search "$@" -i --result-file "$result_file" \
        </dev/tty >/dev/tty 2>/dev/tty
      __atuin_status=$?
      output="$(<"$result_file")"
    } always {
      rm -f -- "$result_file"
    }

    zle reset-prompt
    if [[ -n "${zle_bracketed_paste[1]-}" ]]; then
      print -rn -- "${zle_bracketed_paste[1]}" >/dev/tty
    fi

    if ((__atuin_status != 0)); then
      [[ -n "$output" ]] && print -r -- "$output" >/dev/tty
      return "$__atuin_status"
    fi

    if [[ -n "$output" ]]; then
      # shellcheck disable=SC2034
      RBUFFER=""
      LBUFFER=$output

      if [[ $LBUFFER == __atuin_accept__:* ]]; then
        LBUFFER=${LBUFFER#__atuin_accept__:}
        zle accept-line
      fi
    fi
  }
  zle -N atuin-search _atuin_search
  zle -N atuin-search-vicmd _atuin_search_vicmd
  zle -N atuin-search-viins _atuin_search_viins
fi
unset _atuin_bin

# C1 / shared commands
# interactive.zsh loads cross-shell aliases and then adds Zsh completions.

if [[ -r "$HOME/.config/shell/interactive.zsh" ]]; then
  # shellcheck source=/dev/null
  source "$HOME/.config/shell/interactive.zsh"
fi

# C2 / zoxide
# Load it after the framework so its `cd` alias wins.

if [[ -r "$HOME/.config/shell/zoxide.zsh" ]]; then
  # shellcheck source=/dev/null
  source "$HOME/.config/shell/zoxide.zsh"
fi

# C3 / directory-aware tools
# Load generated hooks when available and fall back to the installed commands
# on a fresh machine.

_broot_bin="$(_dotfiles_command_path broot 2>/dev/null || true)"
if [[ -n "$_broot_bin" && -r "$HOME/.cache/broot/init.zsh" ]]; then
  # shellcheck source=/dev/null
  source "$HOME/.cache/broot/init.zsh"
elif [[ -n "$_broot_bin" ]]; then
  eval "$("$_broot_bin" --print-shell-function zsh)"
fi
unset _broot_bin

if (( $+functions[enable-fzf-tab] )); then
  enable-fzf-tab
fi

# C4 / cleanup
# Remove startup-only helpers from the interactive shell.

unset -f _dotfiles_wrap_command _dotfiles_command_path
