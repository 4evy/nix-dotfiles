# Starship owns the prompt; Atuin waits for a real TTY.
export ZSH="$HOME/.oh-my-zsh"
# shellcheck disable=SC2034
ZSH_THEME=""
# shellcheck disable=SC2034
DISABLE_AUTO_UPDATE="true"
# shellcheck disable=SC2034
DISABLE_UNTRACKED_FILES_DIRTY="true"

# Plugin list, curated and explicit. No surprise guests.
plugins=(
  git
  rust
  nmap
  rsync
  colored-man-pages
  sudo
  extract
  command-not-found
  copypath
  copyfile
  fzf-tab
  zsh-autosuggestions
  zsh-syntax-highlighting
)
if _dotfiles_command_path gh >/dev/null; then
  plugins+=(gh)
fi

# Cached definitions walk in before compinit.
fpath=("$HOME/.cache/zsh/completions" "${fpath[@]}")

# Syntax palette loads before Oh My Zsh wakes the plugin.

if [[ -r "$HOME/.config/shell/zsh-syntax-highlighting.zsh" ]]; then
  # shellcheck source=/dev/null
  source "$HOME/.config/shell/zsh-syntax-highlighting.zsh"
fi

if [[ -r "$ZSH/oh-my-zsh.sh" ]]; then
  # shellcheck source=/dev/null
  source "$ZSH/oh-my-zsh.sh"
fi

# Zellij already manages terminal state; trim duplicate title/cwd reporters.
if [[ -n "${ZELLIJ:-}" ]]; then
  precmd_functions=(${precmd_functions:#_ghostty_deferred_init})
  precmd_functions=(${precmd_functions:#_ghostty_precmd})
  precmd_functions=(${precmd_functions:#omz_termsupport_precmd})
  precmd_functions=(${precmd_functions:#omz_termsupport_cwd})
  preexec_functions=(${preexec_functions:#_ghostty_preexec})
  preexec_functions=(${preexec_functions:#omz_termsupport_preexec})
  chpwd_functions=(${chpwd_functions:#_ghostty_report_pwd})
fi

# B2 вҲҝ ZLE focus sink
#   focus bytes  ESC [ I / ESC [ O  в”Җв”Җв–¶ silent widget в”Җв”Җв–¶ no prompt junk

_dotfiles_disable_terminal_focus_reporting() {
  emulate -L zsh
  [[ -t 1 ]] || return 0
  print -rn -- $'\e[?1004l' >/dev/tty 2>/dev/null || true
}

_dotfiles_ignore_terminal_focus_event() {}
zle -N _dotfiles_ignore_terminal_focus_event
bindkey $'\e[I' _dotfiles_ignore_terminal_focus_event
bindkey $'\e[O' _dotfiles_ignore_terminal_focus_event

# B3 вҲҝ picker / prompt / history lane
#      fzf keymap в”Җв”¬в”Җ keeps Tab free for fzf-tab
#      zstyle hintsв”Ӯ
#      Starship в”Җв”Җв”Җв”јв”Җ prompt chrome
#      Atuin в”Җв”Җв”Җв”Җв”Җв”Җв”ҳ  history search, only on real terminals
#      cache lane: ~/.cache/*/init.zsh  |  fallback: direct init

# Load fzf's key bindings without letting its completion widget steal Tab from
# fzf-tab.
_fzf_init() {
  emulate -L zsh
  local fzf_bin
  fzf_bin="$(_dotfiles_command_path fzf)" || return
  _dotfiles_wrap_command fzf "$fzf_bin"

  local init
  if [[ -r "$HOME/.cache/fzf/init.zsh" ]]; then
    # shellcheck source=/dev/null
    source "$HOME/.cache/fzf/init.zsh"
    return
  fi

  init="$(
    "$fzf_bin" --zsh | sed \
      -e '/^### completion\.zsh ###$/,$d' \
      -e '/^  eval \$__fzf_key_bindings_options$/i\
  __fzf_key_bindings_options=${__fzf_key_bindings_options/ zle on/}\
  __fzf_key_bindings_options=${__fzf_key_bindings_options/ zle off/}'
  )" || return

  eval "$init"
}
_fzf_init
unset -f _fzf_init

zstyle ':completion:*' menu no
zstyle ':completion:*:*:*:*:*' menu no
zstyle ':completion:*:descriptions' format '[%d]'
zstyle ':completion:*' group-name ''
zstyle ':fzf-tab:*' switch-group '<' '>'

# Cached init files are generated by chezmoi; direct command init is the
# fresh-machine fallback.
_starship_bin="$(_dotfiles_command_path starship 2>/dev/null || true)"
if [[ -n "$_starship_bin" ]]; then
  _dotfiles_wrap_command starship "$_starship_bin"
fi
if [[ -n "$_starship_bin" && -r "$HOME/.cache/starship/init.zsh" ]]; then
  # shellcheck source=/dev/null
  source "$HOME/.cache/starship/init.zsh"
elif [[ -n "$_starship_bin" ]]; then
  eval "$("$_starship_bin" init zsh)"
fi
unset _starship_bin
_atuin_bin="$(_dotfiles_command_path atuin 2>/dev/null || true)"
if [[ -t 0 && -t 1 && -n "$_atuin_bin" && -r "$HOME/.cache/atuin/init.zsh" ]]; then
  _dotfiles_wrap_command atuin "$_atuin_bin"
  # shellcheck source=/dev/null
  source "$HOME/.cache/atuin/init.zsh"
  _atuin_search() {
    emulate -L zsh
    zle -I

    local output result_file __atuin_status
    result_file="$(mktemp)" || return 1
    # shellcheck disable=SC2153
    {
      ATUIN_SHELL=zsh \
        ATUIN_LOG=error \
        ATUIN_QUERY=$BUFFER \
        atuin search "$@" -i --result-file "$result_file" \
        </dev/tty >/dev/tty 2>/dev/tty
      __atuin_status=$?
      output="$(<"$result_file")"
    } always {
      rm -f -- "$result_file"
    }

    zle reset-prompt
    if [[ -n "${zle_bracketed_paste[1]-}" ]]; then
      print -rn -- "${zle_bracketed_paste[1]}" >/dev/tty
    fi

    if ((__atuin_status != 0)); then
      [[ -n "$output" ]] && print -r -- "$output" >/dev/tty
      return "$__atuin_status"
    fi

    if [[ -n "$output" ]]; then
      # shellcheck disable=SC2034
      RBUFFER=""
      LBUFFER=$output

      if [[ $LBUFFER == __atuin_accept__:* ]]; then
        LBUFFER=${LBUFFER#__atuin_accept__:}
        zle accept-line
      fi
    fi
  }
  zle -N atuin-search _atuin_search
  zle -N atuin-search-vicmd _atuin_search_vicmd
  zle -N atuin-search-viins _atuin_search_viins
fi
unset _atuin_bin

# C1 вҲҝ command bus
#   ~/.config/shell/interactive.zsh
#      в”ңв”Җ shared aliases + workflows
#      в””в”Җ zsh compdefs after aliases exist

if [[ -r "$HOME/.config/shell/interactive.zsh" ]]; then
  # shellcheck source=/dev/null
  source "$HOME/.config/shell/interactive.zsh"
fi

# C2 вҲҝ zoxide last word
#   framework first, zoxide after; `cd` gets the final say here
#      cwd stream в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв–¶ zoxide db в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв–¶ z / zi

if [[ -r "$HOME/.config/shell/zoxide.zsh" ]]; then
  # shellcheck source=/dev/null
  source "$HOME/.config/shell/zoxide.zsh"
fi

if (( $+functions[enable-fzf-tab] )); then
  enable-fzf-tab
fi

# C3 вҲҝ clean exit
#   startup-only helpers leave before the prompt opens

unset -f _dotfiles_wrap_command _dotfiles_command_path
