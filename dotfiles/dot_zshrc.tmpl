#      в”Ӯ interactive.zsh вҶ’ zoxide owns cd вҶ’ fzf-tab enable  в”Ӯ
#      в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ
#
# cache if warm :: live if fresh :: quiet title/cwd reporting inside Zellij

#  /"\/\_..--------------------._/\/"\
# (     _|| A1 TERM + GHOSTTY  ||_     )
#  \_/\/ || Ghostty + fallback || \/\_/
#        || Zellij gets peace  ||
#  /"\/\_|---------------------|_/\/"\
# (     _|                     |_     )
#  \_/\/ `---------------------' \/\_/
if [[ "${TERM:-}" == "xterm-ghostty" ]] && ! infocmp xterm-ghostty &>/dev/null; then
  export TERM=xterm-256color
fi

if [[ -z "${ZELLIJ:-}" ]] \
  && [[ -n "${GHOSTTY_RESOURCES_DIR:-}" ]] \
  && [[ -r "${GHOSTTY_RESOURCES_DIR}/shell-integration/zsh/ghostty-integration" ]]; then
  source "${GHOSTTY_RESOURCES_DIR}/shell-integration/zsh/ghostty-integration"
fi

# A2 вҲҝ boot tools
#   вҹҰ command path вҹ§в”Җв”Җwrap while init runsв”Җв”ҖвҹҰ unset before prompt вҹ§

_dotfiles_wrap_command() {
  emulate -L zsh
  local -r command_name=$1
  local -r command_path=$2
  eval "$command_name() { command ${(q)command_path} \"\$@\"; }"
}

# A3 вҲҝ repo compass
#        DOTFILES_REPO
#            в”ңв”Җ Darwin вҶ’ ~/Developer/dotfiles вҶ’ ~/dotfiles
#            в””в”Җ else   вҶ’ ~/dotfiles
#   update/check/rebuild come back here before doing heavier work

_dotfiles_repo_path="${DOTFILES_REPO:-}"
if [[ -z "$_dotfiles_repo_path" ]]; then
  case "$(uname -s 2>/dev/null)" in
    Darwin)
      _dotfiles_repo_candidates=("$HOME/Developer/dotfiles" "$HOME/dotfiles")
      ;;
    *)
      _dotfiles_repo_candidates=("$HOME/dotfiles")
      ;;
  esac
  for _dotfiles_repo_candidate in "${_dotfiles_repo_candidates[@]}"; do
    [[ -f "$_dotfiles_repo_candidate/Justfile" ]] || continue
    [[ -d "$_dotfiles_repo_candidate/ansible" ]] || continue
    _dotfiles_repo_path="$_dotfiles_repo_candidate"
    break
  done
fi
if [[ -z "$_dotfiles_repo_path" ]]; then
  _dotfiles_repo_path="$HOME/dotfiles"
fi
if [[ -d "$_dotfiles_repo_path" ]]; then
  _dotfiles_repo_path="$(
    cd -P -- "$_dotfiles_repo_path" 2>/dev/null &&
      pwd ||
      printf '%s\n' "$_dotfiles_repo_path"
  )"
fi
unset _dotfiles_repo_candidate _dotfiles_repo_candidates

_dotfiles_command_path() {
  emulate -L zsh
  (( $+commands[$1] )) || return 1
  print -r -- "$commands[$1]"
}

# A4 вҲҝ provision shim
#   ansible-playbook when it exists; uvx when the machine is still bare

_dotfiles_ansible_playbook() {
  emulate -L zsh
  if command -v ansible-playbook >/dev/null 2>&1; then
    ansible-playbook "$@"
  elif command -v uvx >/dev/null 2>&1; then
    uvx --from ansible-core ansible-playbook "$@"
  else
    print -u2 "ansible-playbook and uvx are not available"
    return 127
  fi
}

#      __^__                         __^__
#     ( ___ )в”Җв”Җв”Җв”Җ B1 PLUGIN RACK в”Җв”Җв”Җ( ___ )
