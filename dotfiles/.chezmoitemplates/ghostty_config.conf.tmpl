{{- $leader := "ctrl+g" -}}
{{- if eq .chezmoi.os "darwin" -}}
{{- $leader = "super+g" -}}
{{- end -}}
theme = light:catppuccin-latte-pink.conf,dark:catppuccin-frappe-pink.conf
background-image = {{ .chezmoi.homeDir }}/.config/ghostty/backgrounds/catppuccin-emoji-corner.png
background-image-opacity = 0.24
background-image-position = bottom-right
{{- if eq .chezmoi.os "darwin" }}
background-image-fit = contain
{{- else }}
background-image-fit = cover
{{- end }}
background-image-repeat = false
custom-shader = {{ .chezmoi.homeDir }}/.config/ghostty/shaders/catppuccin-bubbles.glsl
custom-shader-animation = false
adjust-underline-position = 4
clipboard-paste-protection = true
confirm-close-surface = false
cursor-style = bar
cursor-style-blink = false
font-family = JetBrainsMono Nerd Font Mono
{{- if eq .chezmoi.os "linux" }}
font-family = Noto Color Emoji Bitmap
command = /usr/bin/zsh
env = SHELL=/usr/bin/zsh
{{- else if eq .chezmoi.os "darwin" }}
command = /bin/zsh
env = SHELL=/bin/zsh
{{- end }}
font-size = 14
mouse-scroll-multiplier = precision:1,discrete:3
quit-after-last-window-closed = true
scrollback-limit = 100000000
scrollback-editor = direct:{{ .chezmoi.homeDir }}/.local/bin/terminal-theme-run helix
window-padding-x = 8
window-padding-y = 4
window-padding-balance = true
window-padding-color = extend
shell-integration-features = no-cursor
mouse-hide-while-typing = true

{{- if eq .chezmoi.os "linux" }}
window-theme = ghostty
{{- end }}

{{- if eq .chezmoi.os "darwin" }}
macos-option-as-alt = true
font-thicken = true
{{- end }}

# Keybindings
keybind = clear
{{- if eq .chezmoi.os "darwin" }}
# Emit terminal-native Home/End sequences instead of legacy Ctrl+A/Ctrl+E.
keybind = super+left=text:\x1bOH
keybind = super+right=text:\x1bOF
keybind = super+alt+left=previous_tab
keybind = super+alt+right=next_tab
keybind = super+shift+left=goto_split:left
keybind = super+shift+right=goto_split:right
keybind = super+shift+up=goto_split:up
keybind = super+shift+down=goto_split:down
keybind = super+1=goto_tab:1
keybind = super+2=goto_tab:2
keybind = super+3=goto_tab:3
keybind = super+4=goto_tab:4
keybind = super+5=goto_tab:5
keybind = super+6=goto_tab:6
keybind = super+7=goto_tab:7
keybind = super+8=goto_tab:8
keybind = super+9=goto_tab:9
keybind = super+[=text:\x1b[91;9u
keybind = super+a=text:\x01
keybind = super+b=text:\x02
keybind = super+c=text:\x03
keybind = super+d=text:\x04
keybind = super+e=text:\x05
keybind = super+f=text:\x06
keybind = super+h=text:\x08
keybind = super+i=text:\x09
keybind = super+j=text:\x0a
keybind = super+k=clear_screen
keybind = super+l=text:\x0c
keybind = super+m=text:\x0d
keybind = super+n=text:\x0e
keybind = super+o=text:\x0f
keybind = super+p=text:\x10
keybind = super+q=text:\x11
keybind = super+r=text:\x12
keybind = super+s=text:\x13
keybind = super+t=text:\x14
keybind = super+u=text:\x15
keybind = super+v=text:\x16
keybind = super+w=text:\x17
keybind = super+x=text:\x18
keybind = super+y=text:\x19
keybind = super+z=text:\x1a
keybind = super+shift+backspace=close_surface
keybind = super+shift+r>left=resize_split:left,20
keybind = super+shift+r>down=resize_split:down,20
keybind = super+shift+r>up=resize_split:up,20
keybind = super+shift+r>right=resize_split:right,20
keybind = super+shift+s>left=new_split:left
keybind = super+shift+s>down=new_split:down
keybind = super+shift+s>up=new_split:up
keybind = super+shift+s>right=new_split:right
keybind = super+shift+t=new_tab
keybind = super+shift+n=new_window
keybind = super+0=reset_font_size
keybind = super+equal=increase_font_size:1
keybind = super+shift+equal=increase_font_size:1
keybind = super+minus=decrease_font_size:1
keybind = super+shift+minus=decrease_font_size:1
keybind = copy=text:\x03
keybind = super+shift+c=text:\x1bC
keybind = super+shift+v=paste_from_clipboard
keybind = super+,=reload_config
keybind = super+shift+,=open_config
keybind = super+shift+p=toggle_command_palette
keybind = super+shift+g=navigate_search:previous
keybind = super+shift+f=end_search
keybind = super+shift+w=close_window
keybind = super+shift+[=previous_tab
keybind = super+shift+]=next_tab
keybind = super+page_up=scroll_page_up
keybind = super+page_down=scroll_page_down
keybind = super+home=scroll_to_top
keybind = super+end=scroll_to_bottom
keybind = super+up=jump_to_prompt:-1
keybind = super+down=jump_to_prompt:1
keybind = super+ctrl+f=toggle_fullscreen
{{- end }}
# Emit terminal-native Home/End sequences for line navigation.
keybind = ctrl+left=text:\x1bOH
keybind = ctrl+right=text:\x1bOF
keybind = ctrl+alt+left=previous_tab
keybind = ctrl+alt+right=next_tab
# These shell-compatible sequences are the standard Alt+B/Alt+F word motions.
keybind = alt+left=text:\x1b\x62
keybind = alt+right=text:\x1b\x66
keybind = ctrl+shift+left=goto_split:left
keybind = ctrl+shift+right=goto_split:right
keybind = ctrl+shift+up=goto_split:up
keybind = ctrl+shift+down=goto_split:down
keybind = ctrl+1=goto_tab:1
keybind = ctrl+2=goto_tab:2
keybind = ctrl+3=goto_tab:3
keybind = ctrl+4=goto_tab:4
keybind = ctrl+5=goto_tab:5
keybind = ctrl+6=goto_tab:6
keybind = ctrl+7=goto_tab:7
keybind = ctrl+8=goto_tab:8
keybind = ctrl+9=goto_tab:9
keybind = ctrl+shift+s>left=new_split:left
keybind = ctrl+shift+s>down=new_split:down
keybind = ctrl+shift+s>up=new_split:up
keybind = ctrl+shift+s>right=new_split:right
keybind = ctrl+shift+delete=close_tab:this
keybind = ctrl+0=reset_font_size
keybind = ctrl+equal=increase_font_size:1
keybind = ctrl+shift+equal=increase_font_size:1
keybind = ctrl+minus=decrease_font_size:1
keybind = ctrl+shift+minus=decrease_font_size:1
keybind = ctrl+shift+c=copy_to_clipboard:mixed
keybind = ctrl+shift+v=paste_from_clipboard
keybind = ctrl+shift+backspace=close_surface
keybind = ctrl+k=clear_screen
keybind = ctrl+a=select_all
keybind = ctrl+,=reload_config
keybind = ctrl+shift+,=open_config
keybind = ctrl+shift+p=toggle_command_palette
keybind = copy=copy_to_clipboard:mixed
keybind = paste=paste_from_clipboard
keybind = ctrl+insert=copy_to_clipboard:mixed
keybind = shift+insert=paste_from_selection
keybind = shift+page_up=scroll_page_up
keybind = shift+page_down=scroll_page_down
keybind = shift+home=scroll_to_top
keybind = shift+end=scroll_to_bottom
keybind = ctrl+tab=next_tab
keybind = ctrl+shift+tab=previous_tab
keybind = ctrl+page_up=previous_tab
keybind = ctrl+page_down=next_tab
keybind = ctrl+shift+t=new_tab
keybind = ctrl+shift+n=new_window
keybind = ctrl+shift+w=close_tab:this
keybind = ctrl+enter=toggle_fullscreen
keybind = ctrl+shift+f=start_search

# Ghostty-native tabs, splits, scrolling, and scrollback editing.
keybind = {{ $leader }}>s>e=write_scrollback_file:open
keybind = {{ $leader }}>s>j=scroll_page_lines:1
keybind = {{ $leader }}>s>k=scroll_page_lines:-1
keybind = {{ $leader }}>s>page_down=scroll_page_down
keybind = {{ $leader }}>s>page_up=scroll_page_up
keybind = {{ $leader }}>s>slash=start_search
keybind = {{ $leader }}>t=new_tab
keybind = {{ $leader }}>n=new_window
keybind = {{ $leader }}>q=quit
keybind = {{ $leader }}>1=goto_tab:1
keybind = {{ $leader }}>2=goto_tab:2
keybind = {{ $leader }}>3=goto_tab:3
keybind = {{ $leader }}>4=goto_tab:4
keybind = {{ $leader }}>5=goto_tab:5
keybind = {{ $leader }}>6=goto_tab:6
keybind = {{ $leader }}>7=goto_tab:7
keybind = {{ $leader }}>8=goto_tab:8
keybind = {{ $leader }}>9=goto_tab:9
keybind = {{ $leader }}>h=goto_split:left
keybind = {{ $leader }}>j=goto_split:down
keybind = {{ $leader }}>k=goto_split:up
keybind = {{ $leader }}>l=goto_split:right
keybind = {{ $leader }}>p>left=new_split:left
keybind = {{ $leader }}>p>down=new_split:down
keybind = {{ $leader }}>p>up=new_split:up
keybind = {{ $leader }}>p>right=new_split:right
keybind = {{ $leader }}>p>p=goto_split:previous
keybind = {{ $leader }}>p>x=close_surface
keybind = {{ $leader }}>p>f=toggle_split_zoom
keybind = {{ $leader }}>r>left=resize_split:left,20
keybind = {{ $leader }}>r>down=resize_split:down,20
keybind = {{ $leader }}>r>up=resize_split:up,20
keybind = {{ $leader }}>r>right=resize_split:right,20
keybind = {{ $leader }}>r>equal=equalize_splits
keybind = {{ $leader }}>shift+k=clear_screen
