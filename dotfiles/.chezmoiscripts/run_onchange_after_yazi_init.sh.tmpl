#!/usr/bin/env bash
# shellcheck shell=bash
# yazi package.toml hash: {{ include "dot_config/yazi/package.toml" | sha256sum }}
set -euo pipefail

if ! command -v ya >/dev/null 2>&1; then
	printf '%s\n' 'Yazi plugin install skipped: ya not found' >&2
	exit 0
fi

home_dir=${CHEZMOI_HOME_DIR:-${HOME:?HOME is required}}
config_home=${XDG_CONFIG_HOME:-"$home_dir/.config"}
yazi_config=$config_home/yazi

if [[ ! -f $yazi_config/package.toml ]]; then
	printf 'Yazi plugin install skipped: %s not found\n' "$yazi_config/package.toml" >&2
	exit 0
fi

YAZI_CONFIG_HOME=$yazi_config ya pkg install --discard
