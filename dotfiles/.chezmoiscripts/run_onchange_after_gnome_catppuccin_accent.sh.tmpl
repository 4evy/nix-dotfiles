{{- if eq .chezmoi.os "linux" -}}
#!/usr/bin/env sh
set -eu

accent_bin="$HOME/.local/bin/gnome-catppuccin-accent"

if [ -x "$accent_bin" ]; then
	"$accent_bin" --once || true
fi

if command -v systemctl >/dev/null 2>&1; then
	systemctl --user daemon-reload >/dev/null 2>&1 || true
	systemctl --user enable --now gnome-catppuccin-accent.service >/dev/null 2>&1 || true
fi
{{- end }}
