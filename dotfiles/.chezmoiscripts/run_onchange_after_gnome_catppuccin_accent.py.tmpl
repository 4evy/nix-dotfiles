{{- if eq .chezmoi.os "linux" -}}
{{- $repo := joinPath .chezmoi.sourceDir ".." -}}
#!/usr/bin/env python3
# dotfiles-scripts fingerprint: {{ template "executable_fingerprint" (joinPath .chezmoi.homeDir ".local/bin/dotfiles-scripts") }}
# helper source hash: {{ output "cat" (joinPath $repo "ansible/files/scripts/workstation/chezmoi.py") (joinPath $repo "ansible/files/scripts/workstation/local/user_commands.py") (joinPath $repo "internal/terminaltheme/catppuccin_palette.json") | sha256sum }}
from __future__ import annotations

import os
import shutil
from pathlib import Path

command = Path.home() / ".local/bin/dotfiles-scripts"
if not command.is_file():
    command = Path(shutil.which("dotfiles-scripts") or command)
if command.is_file() and os.access(command, os.X_OK):
    os.execv(command, (command, "chezmoi", "gnome-accent"))
{{- end }}
