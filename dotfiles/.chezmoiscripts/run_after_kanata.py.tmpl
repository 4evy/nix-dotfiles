{{- if eq .chezmoi.os "darwin" -}}
{{- $repo := joinPath .chezmoi.sourceDir ".." -}}
#!/usr/bin/env python3
from __future__ import annotations

import os
import subprocess
from pathlib import Path

fingerprint = "{{ include "dot_config/kanata/kanata-macos.kbd" | sha256sum }}:{{ output "shasum" "-a" "256" (joinPath $repo "ansible/files/scripts/workstation/macos/system.py") (joinPath $repo "ansible/files/scripts/macos/logitech-platform.py") (joinPath $repo "ansible/files/scripts/macos/templates/kanata-app-info.plist.in") (joinPath $repo "ansible/files/scripts/macos/templates/kanata-daemon.plist.in") (joinPath $repo "Formula/kanata-with-cmd.rb") | sha256sum }}"
marker = Path.home() / ".cache/dotfiles/kanata-reconcile.sha256"
state = subprocess.run(
    ("/bin/launchctl", "print", "system/dev.4evy.kanata"),
    check=False,
    capture_output=True,
    text=True,
)
if (
    state.returncode == 0
    and "state = running" in state.stdout
    and marker.is_file()
    and marker.read_text(encoding="utf-8").strip() == fingerprint
):
    raise SystemExit(0)

command = Path.home() / ".local/bin/dotfiles-scripts"
config = Path({{ joinPath .chezmoi.sourceDir "dot_config/kanata/kanata-macos.kbd" | quote }})
if not command.is_file() or not os.access(command, os.X_OK):
    raise SystemExit(f"kanata reconciliation failed: {command} is not executable")

subprocess.run(
    (
        "/usr/bin/sudo",
        "--",
        os.fspath(command),
        "macos",
        "kanata",
        os.fspath(config),
    ),
    check=True,
)
marker.parent.mkdir(parents=True, exist_ok=True)
marker.write_text(f"{fingerprint}\n", encoding="utf-8")
{{- end }}
