{{- if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env python3
from __future__ import annotations

import os
from pathlib import Path

command = Path({{ joinPath .chezmoi.homeDir ".local/bin/dotfiles-scripts" | quote }})
if command.is_file() and os.access(command, os.X_OK):
    os.execv(command, (command, "chezmoi", "alt-tab-license"))
{{- end }}
