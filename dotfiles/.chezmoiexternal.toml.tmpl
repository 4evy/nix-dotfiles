{{- if ne .chezmoi.os "windows" -}}
{{- $yaziConfigPath := "" -}}
{{- if eq .chezmoi.os "darwin" -}}
{{-   $yaziConfigPath = ".config/yazi" -}}
{{- else -}}
{{-   $yaziConfigPath = ".config/yazi" -}}
{{- end -}}

# ----- Oh-My-Zsh -----

[".oh-my-zsh"]
type = "git-repo"
url = "https://github.com/ohmyzsh/ohmyzsh.git"
refreshPeriod = "168h"
[".oh-my-zsh".clone]
args = ["--depth=1"]
[".oh-my-zsh".pull]
args = ["--ff-only"]

[".oh-my-zsh/custom/plugins/zsh-autosuggestions"]
type = "git-repo"
url = "https://github.com/zsh-users/zsh-autosuggestions.git"
refreshPeriod = "168h"
[".oh-my-zsh/custom/plugins/zsh-autosuggestions".clone]
args = ["--depth=1"]
[".oh-my-zsh/custom/plugins/zsh-autosuggestions".pull]
args = ["--ff-only"]

[".oh-my-zsh/custom/plugins/zsh-syntax-highlighting"]
type = "git-repo"
url = "https://github.com/zsh-users/zsh-syntax-highlighting.git"
refreshPeriod = "168h"
[".oh-my-zsh/custom/plugins/zsh-syntax-highlighting".clone]
args = ["--depth=1"]
[".oh-my-zsh/custom/plugins/zsh-syntax-highlighting".pull]
args = ["--ff-only"]

[".oh-my-zsh/custom/plugins/fzf-tab"]
type = "git-repo"
url = "https://github.com/Aloxaf/fzf-tab.git"
refreshPeriod = "168h"
[".oh-my-zsh/custom/plugins/fzf-tab".clone]
args = ["--depth=1"]
[".oh-my-zsh/custom/plugins/fzf-tab".pull]
args = ["--ff-only"]

# ----- Oh-My-Bash -----

[".oh-my-bash"]
type = "git-repo"
url = "https://github.com/ohmybash/oh-my-bash.git"
refreshPeriod = "168h"
[".oh-my-bash".clone]
args = ["--depth=1"]
[".oh-my-bash".pull]
args = ["--ff-only"]

# ----- fzf-tab-completion (bash) -----

[".fzf-tab-completion"]
type = "git-repo"
url = "https://github.com/lincheney/fzf-tab-completion.git"
refreshPeriod = "168h"
[".fzf-tab-completion".clone]
args = ["--depth=1"]
[".fzf-tab-completion".pull]
args = ["--ff-only"]

# ----- Vim -----

[".vim/pack/vendor/start/catppuccin"]
type = "git-repo"
url = "https://github.com/catppuccin/vim.git"
refreshPeriod = "168h"
[".vim/pack/vendor/start/catppuccin".clone]
args = ["--depth=1"]
[".vim/pack/vendor/start/catppuccin".pull]
args = ["--ff-only"]

# ----- Yazi -----

{{- $yaziFlavors := list "frappe" "latte" -}}
{{- range $flavor := $yaziFlavors }}
["{{ $yaziConfigPath }}/flavors/catppuccin-{{ $flavor }}-pink.yazi/flavor.toml"]
type = "file"
url = "https://raw.githubusercontent.com/catppuccin/yazi/main/themes/{{ $flavor }}/catppuccin-{{ $flavor }}-pink.toml"
refreshPeriod = "168h"
{{ end }}

# ----- Zellij -----

[".local/share/zellij/plugins/zjstatus.wasm"]
type = "file"
url = "https://github.com/dj95/zjstatus/releases/latest/download/zjstatus.wasm"
refreshPeriod = "168h"

{{- end }}
