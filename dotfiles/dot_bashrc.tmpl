# shellcheck shell=bash
#       ▄▄                            ▄▄
#       ██                            ██
#       ██▄███▄    ▄█████▄  ▄▄█████▄  ██▄████▄
#       ██▀  ▀██   ▀ ▄▄▄██  ██▄▄▄▄ ▀  ██▀   ██
#       ██    ██  ▄██▀▀▀██   ▀▀▀▀██▄  ██    ██
#       ███▄▄██▀  ██▄▄▄███  █▄▄▄▄▄██  ██    ██
#       ▀▀ ▀▀▀     ▀▀▀▀ ▀▀   ▀▀▀▀▀▀   ▀▀    ▀▀
#       B A S H / signal deck
#  .bashenv 〰 terminal tune-up 〰 Oh My Bash
#  starship/fzf/atuin 〰 shared commands 〰 zoxide
#  ░▒▓ scripts stay quiet; interactive shells get the full rig

# ✦ 00 / airlock
#      .bashenv brings PATH + exports; prompt work waits behind `$-`.
# shellcheck source=/dev/null
[[ -r "$HOME/.bashenv" ]] && source "$HOME/.bashenv"

# ✦ 01 / terminal tuning fork
#      Ghostty gets its integration; missing terminfo drops to a common signal.
if [[ -n "${GHOSTTY_RESOURCES_DIR:-}" ]] &&
	[[ -r "${GHOSTTY_RESOURCES_DIR}/shell-integration/bash/ghostty.bash" ]]; then
	builtin source "${GHOSTTY_RESOURCES_DIR}/shell-integration/bash/ghostty.bash"
fi

if [[ "${TERM:-}" == "xterm-ghostty" ]] && ! infocmp xterm-ghostty &>/dev/null; then
	export TERM=xterm-256color
fi

[[ $- != *i* ]] && return

{{- if eq .chezmoi.os "linux" }}
_dotfiles_path_append_once() {
	local candidate

	for candidate; do
		[[ -n "$candidate" ]] || continue
		case ":${PATH:-}:" in
			*":$candidate:"*) ;;
			*) PATH="${PATH:+$PATH:}$candidate" ;;
		esac
	done
}

_dotfiles_brew_prefix="${HOMEBREW_PREFIX:-}"
if [[ -z "$_dotfiles_brew_prefix" ]]; then
	if [[ -d /home/linuxbrew/.linuxbrew ]]; then
		_dotfiles_brew_prefix=/home/linuxbrew/.linuxbrew
	elif [[ -d "$HOME/.linuxbrew" ]]; then
		_dotfiles_brew_prefix="$HOME/.linuxbrew"
	fi
fi
if [[ -n "$_dotfiles_brew_prefix" ]]; then
	export HOMEBREW_PREFIX="$_dotfiles_brew_prefix"
	export HOMEBREW_CELLAR="$HOMEBREW_PREFIX/Cellar"
	if [[ "$HOMEBREW_PREFIX" == /home/linuxbrew/.linuxbrew ]]; then
		export HOMEBREW_REPOSITORY="$HOMEBREW_PREFIX/Homebrew"
	else
		export HOMEBREW_REPOSITORY="$HOMEBREW_PREFIX"
	fi
	_dotfiles_path_append_once "$HOMEBREW_PREFIX/bin" "$HOMEBREW_PREFIX/sbin"
	export PATH
fi
unset _dotfiles_brew_prefix
unset -f _dotfiles_path_append_once
{{- end }}

# ✦ 02 / tiny Bash manners
#      shopt keeps glob and array expansion behavior predictable.
shopt -s array_expand_once globskipdots

# ✦ 03 / loader rig
#      Resolve real binaries once, then wrap them while init scripts load.

_dotfiles_wrap_command() {
	local -r command_name=$1
	local -r command_path=$2
	local quoted_path

	printf -v quoted_path '%q' "$command_path"
	eval "$command_name() { command $quoted_path \"\$@\"; }"
}

_dotfiles_command_path() {
	local command_path
	command_path="$(type -P -- "$1")" || return 1
	[[ -n "$command_path" ]] || return 1
	printf '%s\n' "$command_path"
}

# ✦ 04 / repo coordinate
#      DOTFILES_REPO wins; platform defaults are probed and normalized after.

_dotfiles_ansible_playbook() {
	if command -v ansible-playbook >/dev/null 2>&1; then
		ansible-playbook "$@"
	elif command -v uvx >/dev/null 2>&1; then
		uvx --from ansible-core ansible-playbook "$@"
	else
		printf '%s\n' "ansible-playbook and uvx are not available" >&2
		return 127
	fi
}

_dotfiles_repo_path="${DOTFILES_REPO:-}"
if [[ -z "$_dotfiles_repo_path" ]]; then
	case "$(uname -s 2>/dev/null)" in
		Darwin)
			_dotfiles_repo_candidates=("$HOME/Developer/dotfiles" "$HOME/dotfiles")
			;;
		*)
			_dotfiles_repo_candidates=("$HOME/dotfiles")
			;;
	esac
	for _dotfiles_repo_candidate in "${_dotfiles_repo_candidates[@]}"; do
		[[ -f "$_dotfiles_repo_candidate/Justfile" ]] || continue
		[[ -d "$_dotfiles_repo_candidate/ansible" ]] || continue
		_dotfiles_repo_path="$_dotfiles_repo_candidate"
		break
	done
fi
if [[ -z "$_dotfiles_repo_path" ]]; then
	_dotfiles_repo_path="$HOME/dotfiles"
fi
if [[ -d "$_dotfiles_repo_path" ]]; then
	_dotfiles_repo_path="$(
		cd -P -- "$_dotfiles_repo_path" 2>/dev/null &&
			pwd ||
			printf '%s\n' "$_dotfiles_repo_path"
	)"
fi
unset _dotfiles_repo_candidate _dotfiles_repo_candidates

# ✦ 05 / Oh My Bash frame
#      Framework plugins load here; daily commands wait in the shared bus.
export OSH="$HOME/.oh-my-bash"
# shellcheck disable=SC2034
OSH_THEME=""

# Plugin list, no mystery guests.
# shellcheck disable=SC2034
plugins=(git bashmarks)

# Completion list; gh joins only when present.
completions=(git ssh system)
if _dotfiles_command_path gh >/dev/null; then
	completions+=(gh)
fi

# Shared commands come later, after framework setup.
# shellcheck disable=SC2034
aliases=()

if [[ -r "$OSH/oh-my-bash.sh" ]]; then
	# shellcheck source=/dev/null
	source "$OSH/oh-my-bash.sh"
fi

# ✦ 06 / Readline focus sink
#      Terminal focus events become no-op Readline keys.

_dotfiles_disable_terminal_focus_reporting() {
	[[ -t 1 ]] || return 0
	printf '\e[?1004l' >/dev/tty 2>/dev/null || true
}

bind '"\e[I": ""' 2>/dev/null || true
bind '"\e[O": ""' 2>/dev/null || true

# ✦ 07 / prompt + picker rail
#      starship ⇢ fzf ⇢ atuin; cache wins, live init covers first boot.
_starship_bin="$(_dotfiles_command_path starship 2>/dev/null || true)"
if [[ -n "$_starship_bin" ]]; then
	_dotfiles_wrap_command starship "$_starship_bin"
fi
if [[ -n "$_starship_bin" && -r "$HOME/.cache/starship/init.bash" ]]; then
	# shellcheck source=/dev/null
	source "$HOME/.cache/starship/init.bash"
elif [[ -n "$_starship_bin" ]]; then
	eval "$("$_starship_bin" init bash)"
fi
unset _starship_bin
_fzf_bin="$(_dotfiles_command_path fzf 2>/dev/null || true)"
if [[ -n "$_fzf_bin" ]]; then
	_dotfiles_wrap_command fzf "$_fzf_bin"
	if [[ -r "$HOME/.cache/fzf/init.bash" ]]; then
		# shellcheck source=/dev/null
		source "$HOME/.cache/fzf/init.bash"
	else
		eval "$("$_fzf_bin" --bash)"
	fi
fi
unset _fzf_bin
_atuin_bin="$(_dotfiles_command_path atuin 2>/dev/null || true)"
if [[ -t 0 && -t 1 && -n "$_atuin_bin" && -r "$HOME/.cache/atuin/init.bash" ]]; then
	_dotfiles_wrap_command atuin "$_atuin_bin"
	# shellcheck source=/dev/null
	source "$HOME/.cache/atuin/init.bash"
	__atuin_search_cmd() (
		local -a search_args=("$@")
		local result_file status

		result_file="$(mktemp)" || exit 1
		trap 'rm -f -- "$result_file"' EXIT
		ATUIN_SHELL=bash \
			ATUIN_LOG=error \
			ATUIN_QUERY=$READLINE_LINE \
			atuin search "${search_args[@]}" -i --result-file "$result_file" 1>&2
		status=$?
		cat -- "$result_file"
		exit "$status"
	)
fi
unset _atuin_bin

# ✦ 08 / completion cache
#      Generated shards stay in ~/.cache/bash/completions.
for f in "$HOME/.cache/bash/completions"/*; do
	# shellcheck source=/dev/null
	[[ -f "$f" ]] && source "$f"
done

# ✦ 09 / command bus
#      Shared aliases enter after prompt and framework wiring.

if [[ -r "$HOME/.config/shell/interactive.bash" ]]; then
	# shellcheck source=/dev/null
	source "$HOME/.config/shell/interactive.bash"
fi

# ✦ 10 / zoxide last word
#      zoxide loads late so its cd wrapper wins.

if [[ -r "$HOME/.config/shell/zoxide.bash" ]]; then
	# shellcheck source=/dev/null
	source "$HOME/.config/shell/zoxide.bash"
fi

# ✦ 11 / clean exit
#      Startup helpers leave before the prompt appears.

unset -f _dotfiles_wrap_command _dotfiles_command_path
