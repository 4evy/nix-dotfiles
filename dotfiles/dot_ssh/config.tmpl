{{- $onePasswordAgent := "%d/.1password/agent.sock" -}}
{{- if eq .chezmoi.os "darwin" -}}
{{- $onePasswordAgent = "%d/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock" -}}
{{- end }}
Host github github.com
  Hostname ssh.github.com
  Port 443
  User git
  ForwardAgent no
  UserKnownHostsFile ~/.ssh/known_hosts ~/.ssh/known_hosts.d/github

Host codeberg.org
  Hostname codeberg.org
  Port 22
  User git
  ForwardAgent no
  UserKnownHostsFile ~/.ssh/known_hosts ~/.ssh/known_hosts.d/codeberg

Host ublue
  HostName ublue
  ForwardAgent yes

Match host * exec "test -z \"$SSH_CONNECTION\" && test -z \"$SSH_AUTH_SOCK\""
  IdentityAgent "{{ $onePasswordAgent }}"

Host *
  AddKeysToAgent no
  ForwardAgent no
  HashKnownHosts yes
  KexAlgorithms mlkem768x25519-sha256,sntrup761x25519-sha512,sntrup761x25519-sha512@openssh.com,curve25519-sha256,curve25519-sha256@libssh.org,ecdh-sha2-nistp256,ecdh-sha2-nistp384,ecdh-sha2-nistp521,diffie-hellman-group-exchange-sha256,diffie-hellman-group16-sha512,diffie-hellman-group18-sha512,diffie-hellman-group14-sha256
