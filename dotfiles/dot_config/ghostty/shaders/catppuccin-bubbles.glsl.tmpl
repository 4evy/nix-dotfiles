// A quiet Catppuccin-pink corner glow behind the emoji background image.
// Generated per platform because Metal and OpenGL disagree about +Y.

void mainImage(out vec4 fragColor, in vec2 fragCoord) {
    vec2 sample_uv = fragCoord / iResolution.xy;
    vec2 screen_uv = sample_uv;
{{- if ne .chezmoi.os "darwin" }}
    // OpenGL gives us a bottom-left origin; use a top-left design space.
    screen_uv.y = 1.0 - screen_uv.y;
{{- end }}

    vec4 terminal = texture(iChannel0, sample_uv);

    // Use Ghostty's semantic color uniforms for theme decisions. iChannel0 is
    // the fully rendered terminal: sampling it here would let a TUI cell,
    // selection, or diff background under that coordinate change the glow for
    // the entire surface.
    float background_luma = dot(
        iBackgroundColor,
        vec3(0.2126, 0.7152, 0.0722)
    );
    vec3 pink = iPalette[5];

    // Let a restrained diagonal bleed extend out from the emoji corner without
    // concentrating the tint at the edge. Linear-space blending makes even a
    // few percent read strongly, so keep the peak deliberately low.
    float bleed = smoothstep(
        0.05,
        1.10,
        (screen_uv.x + screen_uv.y) * 0.5
    );
    float glow_strength = background_luma < 0.5 ? 0.019 : 0.120;
    float glow = bleed * glow_strength;

    // Apply after terminal rendering so the flavor survives full-screen TUIs.
    vec3 color = mix(terminal.rgb, pink, clamp(glow, 0.0, 0.120));
    fragColor = vec4(color, terminal.a);
}
