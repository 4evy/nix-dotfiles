[user]
name = "4evy"
email = "git@evy.pink"

[ui]
color = "auto"
paginate = "auto"
merge-editor = "vscode"
diff-formatter = ":git"
default-command = "log"

[git]
sign-on-push = true

{{ if lookPath "watchman" -}}
[fsmonitor]
backend = "watchman"

[fsmonitor.watchman]
register-snapshot-trigger = true
{{ end -}}

[signing]
behavior = "drop"
backend = "ssh"
key = "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIPsZFHUhLSPiz0EF1Q59jzu7IS7qdn3MSEImztN4KgmN"

[signing.backends.ssh]
program = {{ if eq .chezmoi.os "darwin" -}}
"/Applications/1Password.app/Contents/MacOS/op-ssh-sign"
{{- else -}}
"/opt/1Password/op-ssh-sign"
{{- end }}
allowed-signers = "{{ .chezmoi.homeDir }}/.ssh/allowed_signers"

[aliases]
d = ["describe"]
p = ["git", "push"]
e = ["edit"]
n = ["new"]
redate.definition = ["util", "exec", "--", "jj-redate"]
redate.doc = "Interactively set timestamps and sign rewritten revisions"
get.definition = ["util", "exec", "--", "jj-get"]
get.doc = "Fetch and track a remote Git branch or GitHub pull request"

[templates]
git_push_bookmark = '"4evy/push-" ++ change_id.short()'
duplicate_description = 'concat(description, "\n(cherry picked from commit ", commit_id, ")")'
