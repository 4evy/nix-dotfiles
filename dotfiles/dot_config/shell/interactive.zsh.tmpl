# zsh adapter / compdef splice
#  shared command bus ⟶ compdef(_python, _pip)
#  ⠁ completion names stay native after aliases load

# Pull in the shared command bus.

if [[ -r "$HOME/.config/shell/interactive.common.sh" ]]; then
  source "$HOME/.config/shell/interactive.common.sh"
fi

# Finish with Zsh completion wiring for Python and pip.

if (( $+functions[compdef] )); then
  compdef _python python python3
  compdef _pip pip pip3
fi
