jj() {
	local shim_result
	local shim_state
	local shim_status

	if [[ $# -ge 2 && "$1" == git && "$2" == fetch && -x "$HOME/.local/bin/jj-git-fetch" ]]; then
		if ! shim_state="$(mktemp "${TMPDIR:-/tmp}/jj-git-fetch-shim.XXXXXX")"; then
			command jj "$@"
			return
		fi

		shim_status=0
		JJ_GIT_FETCH_SHIM_STATE="$shim_state" "$HOME/.local/bin/jj-git-fetch" "$@" || shim_status=$?
		shim_result="$(<"$shim_state")"
		rm -f -- "$shim_state"

		if [[ "$shim_result" == handled ]]; then
			return "$shim_status"
		fi
		if [[ "$shim_result" != delegate ]]; then
			return "$shim_status"
		fi
	fi

	command jj "$@"
}

_dotfiles_tk_path_is_lock() {
	case "$1" in
		flake.lock | */flake.lock | \
			Cargo.lock | */Cargo.lock | \
			composer.lock | */composer.lock | \
			Gemfile.lock | */Gemfile.lock | \
			go.sum | */go.sum | \
			npm-shrinkwrap.json | */npm-shrinkwrap.json | \
			package-lock.json | */package-lock.json | \
			Pipfile.lock | */Pipfile.lock | \
			pnpm-lock.yaml | */pnpm-lock.yaml | \
			poetry.lock | */poetry.lock | \
			bun.lock | */bun.lock | \
			bun.lockb | */bun.lockb | \
			uv.lock | */uv.lock | \
			yarn.lock | */yarn.lock)
			return 0
			;;
	esac
	return 1
}

tk() (
	local root prefix tmp tracked attrs mirror
	local file_path attr_name value raw arg_max arg_bytes dest dest_dir
	local -a tokei_args pathspecs git_pathspecs files

	if ! command -v tokei >/dev/null 2>&1; then
		printf '%s\n' "tokei is not installed" >&2
		exit 127
	fi

	if ! command -v git >/dev/null 2>&1 ||
		! root="$(git rev-parse --show-toplevel 2>/dev/null)" ||
		[[ -z "$root" ]]; then
		command tokei "$@"
		exit
	fi

	prefix="$(git rev-parse --show-prefix 2>/dev/null || true)"

	tokei_args=()
	pathspecs=()
	while (($#)); do
		if [[ "$1" == "--" ]]; then
			shift
			pathspecs=("$@")
			break
		fi
		tokei_args+=("$1")
		shift
	done

	git_pathspecs=()
	if ((${#pathspecs[@]} == 0)); then
		if [[ -n "$prefix" ]]; then
			git_pathspecs=("$prefix")
		else
			git_pathspecs=(".")
		fi
	else
		for raw in "${pathspecs[@]}"; do
			case "$raw" in
				:*)
					git_pathspecs+=("$raw")
					;;
				"$root")
					git_pathspecs+=(".")
					;;
				"$root"/*)
					git_pathspecs+=("${raw#"$root"/}")
					;;
				/*)
					git_pathspecs+=("$raw")
					;;
				*)
					git_pathspecs+=("${prefix}${raw}")
					;;
			esac
		done
	fi

	tmp="$(mktemp -d "${TMPDIR:-/tmp}/tk.XXXXXXXX")" || exit
	trap 'rm -rf -- "$tmp"' EXIT HUP INT TERM
	tracked="$tmp/tracked.z"
	attrs="$tmp/attrs.z"

	if ! git -C "$root" ls-files -z --cached --deduplicate --full-name -- "${git_pathspecs[@]}" >"$tracked"; then
		exit
	fi

	if [[ ! -s "$tracked" ]]; then
		printf '%s\n' "tk: no tracked files under requested scope" >&2
		exit 0
	fi

	cd "$root" || exit
	files=()
	if git check-attr --stdin -z linguist-generated <"$tracked" >"$attrs" 2>/dev/null; then
		while IFS= read -r -d '' file_path &&
			IFS= read -r -d '' attr_name &&
			IFS= read -r -d '' value; do
			: "$attr_name"
			[[ -e "$file_path" && ! -d "$file_path" ]] || continue
			case "$value" in
				set | true)
					continue
					;;
			esac
			if _dotfiles_tk_path_is_lock "$file_path"; then
				continue
			fi
			files+=("$file_path")
		done <"$attrs"
	else
		while IFS= read -r -d '' file_path; do
			[[ -e "$file_path" && ! -d "$file_path" ]] || continue
			if _dotfiles_tk_path_is_lock "$file_path"; then
				continue
			fi
			files+=("$file_path")
		done <"$tracked"
	fi

	if ((${#files[@]} == 0)); then
		printf '%s\n' "tk: no tracked, non-generated files to count" >&2
		exit 0
	fi

	arg_bytes=0
	for raw in "${tokei_args[@]}" "${files[@]}"; do
		arg_bytes=$((arg_bytes + ${#raw} + 1))
	done
	arg_max="$(getconf ARG_MAX 2>/dev/null || printf '%s\n' 262144)"
	case "$arg_max" in
		'' | *[!0-9]*)
			arg_max=262144
			;;
	esac

	if ((arg_bytes < arg_max - 32768)); then
		command tokei "${tokei_args[@]}" -- "${files[@]}"
		exit
	fi

	mirror="$tmp/tree"
	mkdir -p -- "$mirror" || exit
	for file_path in "${files[@]}"; do
		dest="$mirror/$file_path"
		dest_dir="${dest%/*}"
		mkdir -p -- "$dest_dir" || exit
		if [[ -L "$file_path" ]]; then
			cp -pL -- "$file_path" "$dest" || exit
		else
			ln -- "$file_path" "$dest" 2>/dev/null || cp -p -- "$file_path" "$dest" || exit
		fi
	done

	command tokei "${tokei_args[@]}" --hidden -- "$mirror"
)

# B1 / host runner
#      uses sudo -n and stays honest

_dotfiles_system_runner() {
	local runner="$HOME/.local/bin/system-runner"
	local env_args=(
		--env "PATH=$PATH"
		--env "HOME=$HOME"
	)

	if [[ ! -x "$runner" ]]; then
		printf '%s\n' "system-runner is not installed" >&2
		return 127
	fi

	[[ -z ${XDG_CONFIG_HOME-} ]] || env_args+=(--env "XDG_CONFIG_HOME=$XDG_CONFIG_HOME")
	[[ -z ${XDG_DATA_HOME-} ]] || env_args+=(--env "XDG_DATA_HOME=$XDG_DATA_HOME")
	[[ -z ${XDG_CACHE_HOME-} ]] || env_args+=(--env "XDG_CACHE_HOME=$XDG_CACHE_HOME")
	[[ -z ${XDG_STATE_HOME-} ]] || env_args+=(--env "XDG_STATE_HOME=$XDG_STATE_HOME")
	[[ -z ${TERM-} ]] || env_args+=(--env "TERM=$TERM")
	[[ -z ${COLORTERM-} ]] || env_args+=(--env "COLORTERM=$COLORTERM")

	sudo -n "$runner" "${env_args[@]}" -- "$@"
}

free() {
	_dotfiles_system_runner "$@"
}

## usage: f COMMAND [ARG...]
f_usage() {
	sed -n 's/^##[[:space:]]\{0,1\}//p' "${BASH_SOURCE[0]}"
}

f() {
	if (($# == 0)); then
		f_usage >&2
		return 2
	fi

	case "$1" in
		cza)
			shift
			free chezmoi apply --force "$@"
			;;
		*)
			free "$@"
			;;
	esac
}

