#!/usr/bin/env bash
# shellcheck shell=bash
set -euo pipefail

section() {
	printf '\n== %s ==\n' "$1"
}

section system
hostnamectl 2>/dev/null || true
printf 'session=%s desktop=%s\n' "${XDG_SESSION_TYPE:-unknown}" "${XDG_CURRENT_DESKTOP:-unknown}"
printf 'kernel=%s\n' "$(uname -r)"
command -v rpm-ostree >/dev/null 2>&1 && rpm-ostree status 2>/dev/null || true
command -v bootc >/dev/null 2>&1 && bootc status 2>/dev/null || true

section graphics
lspci -nnk 2>/dev/null | sed -n '/VGA\|3D\|Display/,+4p' || true
ls -l /dev/dri 2>/dev/null || true
lsmod | rg '^(nvidia|nouveau|amdgpu|i915)' || true
for device in /sys/class/drm/card[0-9]/device; do
	[[ -e $device ]] || continue
	printf '%s vendor=' "$device"
	cat "$device/vendor" 2>/dev/null || true
	printf '%s device=' "$device"
	cat "$device/device" 2>/dev/null || true
done
command -v nvidia-smi >/dev/null 2>&1 && nvidia-smi || true
rpm -qa 2>/dev/null | rg -i '^(nvidia|kmod-nvidia|akmod-nvidia|xorg-x11-nvidia|libnvidia|libva-nvidia|libva-utils|egl-wayland|egl-wayland2|ublue-os-nvidia|vulkan-loader|vulkan-tools)' | sort || true

section graphics-apis
command -v glxinfo >/dev/null 2>&1 && glxinfo -B 2>/dev/null || true
command -v eglinfo >/dev/null 2>&1 && eglinfo -B 2>/dev/null || true
command -v vainfo >/dev/null 2>&1 && vainfo --display wayland 2>/dev/null || true
if command -v vulkaninfo >/dev/null 2>&1; then
	vulkaninfo --summary 2>/dev/null || true
else
	printf '%s\n' 'vulkaninfo not available'
fi

section flatpak-gl
if command -v flatpak >/dev/null 2>&1; then
	flatpak --gl-drivers 2>/dev/null || true
	flatpak list --runtime --columns=application,branch,arch,origin,installation 2>/dev/null |
		rg -i 'nvidia|org\.freedesktop\.Platform\.(GL|VAAPI)' || true
fi

section power
powerprofilesctl get 2>/dev/null || true
for file in \
	/sys/devices/system/cpu/cpu0/cpufreq/scaling_governor \
	/sys/devices/system/cpu/cpu0/cpufreq/energy_performance_preference; do
	[[ -r $file ]] && printf '%s=%s\n' "$file" "$(<"$file")"
done

section pressure
uptime || true
free -h || true
command -v systemd-inhibit >/dev/null 2>&1 && systemd-inhibit --list --no-pager || true

section failed-units
systemctl --failed --no-pager || true
systemctl --user --failed --no-pager || true

section gnome
gsettings get org.gnome.shell enabled-extensions 2>/dev/null || true
gnome-extensions list --enabled 2>/dev/null || true
journalctl --user -b --no-pager -p warning..alert 2>/dev/null |
	rg -i 'gnome-shell|mutter|extension|clutter|st_widget|g_closure|gpu|egl|vulkan|wayland' |
	tail -80 || true

section chromium
ps -eo pid,ppid,pcpu,pmem,comm,args --sort=-pcpu |
	rg -i 'helium|chrom|electron|discord' |
	head -40 || true

section kernel-gpu
journalctl -k -b --no-pager 2>/dev/null |
	rg -i 'nouveau|nvidia|amdgpu|i915|drm|gpu|xid|timeout|hang|stall|firmware' |
	tail -120 || true

section hot-processes
ps -eo pid,ppid,ni,pri,psr,pcpu,pmem,comm,args --sort=-pcpu | head -30 || true
