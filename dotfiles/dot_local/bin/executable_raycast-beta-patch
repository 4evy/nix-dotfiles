#!/usr/bin/env bash
# shellcheck shell=bash
set -euo pipefail

log() {
	printf 'raycast-beta-patch: %s\n' "$*" >&2
}

warn() {
	printf 'raycast-beta-patch: warning: %s\n' "$*" >&2
}

die() {
	printf 'raycast-beta-patch: error: %s\n' "$*" >&2
	exit 1
}

require_command() {
	local command_name

	for command_name; do
		command -v "$command_name" >/dev/null 2>&1 || die "required command is not available: $command_name"
	done
}

require_file() {
	local path=${1:?file path is required}

	[[ -f $path ]] || die "required file does not exist: $path"
}

trim_file() {
	sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//' "$1"
}

preview_secret() {
	local value=${1:?value is required}
	local prefix=${2:?prefix is required}

	if ((${#value} <= prefix)); then
		printf '%s\n' "$value"
	else
		printf '%s...\n' "${value:0:prefix}"
	fi
}

write_keydump_hook() {
	local hook_file=${1:?hook file is required}
	local key_file=${2:?key file is required}
	local key_file_json
	local line

	key_file_json=$(jq -Rn --arg path "$key_file" '$path')
	while IFS= read -r line || [[ -n $line ]]; do
		printf '%s\n' "${line//__KEY_FILE_JSON__/$key_file_json}"
	done <"$keydump_hook_source" >"$hook_file"
}

write_node_wrapper() {
	local node_path=${1:?node path is required}
	local node_real=${2:?real node path is required}
	local hook_file=${3:?hook file is required}
	local node_real_quoted
	local hook_file_quoted

	node_real_quoted=$(printf '%q' "$node_real")
	hook_file_quoted=$(printf '%q' "$hook_file")
	cat >"$node_path" <<EOF
#!/usr/bin/env bash
# shellcheck shell=bash

exec $node_real_quoted --require $hook_file_quoted "\$@"
EOF
	chmod 0755 "$node_path"
}

restore_original_node() {
	local node_path=${1:?node path is required}
	local node_real=${2:?real node path is required}
	local hook_file=${3:?hook file is required}

	[[ -f $node_real ]] || return 0
	rm -f "$node_path"
	mv "$node_real" "$node_path"
	rm -f "$hook_file"
}

install_restore_trap() {
	local node_path=${1:?node path is required}
	local node_real=${2:?real node path is required}
	local hook_file=${3:?hook file is required}
	local node_path_quoted
	local node_real_quoted
	local hook_file_quoted

	node_path_quoted=$(printf '%q' "$node_path")
	node_real_quoted=$(printf '%q' "$node_real")
	hook_file_quoted=$(printf '%q' "$hook_file")
	# Expand the quoted paths now so cleanup still has them after extract_key returns.
	# shellcheck disable=SC2064
	trap "restore_original_node $node_path_quoted $node_real_quoted $hook_file_quoted || warn 'failed to restore Raycast node'" EXIT
}

read_key() {
	local key_file=${1:?key file is required}
	local key

	[[ -f $key_file ]] || return 1
	key=$(trim_file "$key_file")
	[[ -n $key ]] || die "raycast DB key cache is empty: $key_file"
	printf '%s\n' "$key"
}

wait_for_file() {
	local path=${1:?path is required}
	local attempts=${2:?attempts is required}
	local interval=${3:?interval is required}
	local attempt=0

	while ((attempt < attempts)); do
		[[ -f $path ]] && return 0
		sleep "$interval"
		((attempt += 1))
	done

	return 1
}

open_beta() {
	open "$beta_app"
}

find_raycast_node_dir() {
	local runtime_root=$app_support/node/runtime
	local node_dir

	[[ -d $runtime_root ]] || die "raycast node runtime not found: $runtime_root"
	node_dir=$(
		for candidate in "$runtime_root"/node-v*/bin; do
			[[ -d $candidate ]] || continue
			if [[ -f $candidate/node || -f $candidate/node.real ]]; then
				printf '%s\n' "$candidate"
			fi
		done | sort | tail -n 1
	)
	[[ -n $node_dir ]] || die "raycast node runtime not found under $runtime_root"
	printf '%s\n' "$node_dir"
}

extract_key() {
	local node_dir
	local hook_file
	local key_file
	local node_path
	local node_real
	local key

	node_dir=$(find_raycast_node_dir)
	hook_file=$node_dir/.keydump.cjs
	key_file=$node_dir/.raycast-key-cache
	node_path=$node_dir/node
	node_real=$node_dir/node.real

	if [[ -f $node_real ]]; then
		restore_original_node "$node_path" "$node_real" "$hook_file"
	fi

	if key=$(read_key "$key_file"); then
		raycast_node=$node_path
		raycast_key=$key
		return 0
	fi

	write_keydump_hook "$hook_file" "$key_file"
	if ! mv "$node_path" "$node_real"; then
		rm -f "$hook_file"
		die "failed to move Raycast node aside: $node_path"
	fi
	if ! write_node_wrapper "$node_path" "$node_real" "$hook_file"; then
		mv "$node_real" "$node_path" || true
		rm -f "$hook_file"
		die "failed to write Raycast node wrapper: $node_path"
	fi

	install_restore_trap "$node_path" "$node_real" "$hook_file"

	log 'extracting Raycast DB key'
	open_beta
	if wait_for_file "$key_file" "$key_capture_retries" "$key_capture_interval"; then
		killall 'Raycast Beta' >/dev/null 2>&1 || true
		sleep 2
	else
		killall 'Raycast Beta' >/dev/null 2>&1 || true
		die 'failed to capture Raycast DB key; Raycast may not have started'
	fi

	key=$(read_key "$key_file")
	restore_original_node "$node_path" "$node_real" "$hook_file"
	trap - EXIT

	log "Raycast DB key extracted: $(preview_secret "$key" 16) (${#key} bytes)"
	raycast_node=$node_path
	raycast_key=$key
}

resize_avatar() {
	local source=${1:?source is required}
	local destination=${2:?destination is required}

	sips -Z 256 "$source" --out "$destination" >/dev/null
}

ensure_avatar() {
	local avatar_url
	local source
	local temp

	if [[ -f $avatar_path ]]; then
		log "avatar exists: $avatar_path"
		return 0
	fi

	mkdir -p "$app_support"
	source=${RAYCAST_AVATAR_SRC:-}
	if [[ -n $source && -f $source ]]; then
		if resize_avatar "$source" "$avatar_path"; then
			log "avatar resized from $source"
			return 0
		fi
	fi

	avatar_url=$(yq -r '.avatar_url // ""' "$profile_file")
	if [[ -z $avatar_url ]]; then
		warn "profile is missing avatar_url; continuing without avatar refresh"
		return 0
	fi

	temp=$(mktemp "${TMPDIR:-/tmp}/raycast-beta-avatar-source.XXXXXX.png")
	if curl -fsSL -A dotfiles-raycast-beta-patch -o "$temp" "$avatar_url"; then
		if resize_avatar "$temp" "$avatar_path"; then
			log "avatar downloaded and resized from $avatar_url"
		fi
	else
		warn 'failed to download Raycast avatar; continuing without avatar refresh'
	fi
	rm -f "$temp"
}

file_url() {
	local path=${1:?path is required}

	jq -rn --arg path "$path" '$path | split("/") | map(@uri) | join("/") | "file://" + .'
}

write_user_defaults() {
	local profile_json
	local avatar_file_url
	local current_user
	local oauth_token

	profile_json=$(yq -o=json '.' "$profile_file")
	avatar_file_url=$(file_url "$avatar_path")
	current_user=$(
		jq -cer --arg avatar "$avatar_file_url" '
			.current_user
			| if (.id // "") == "" or (.name // "") == "" then
				error("profile is missing current_user identity")
			else
				.image = $avatar
				| .avatar = $avatar
			end
		' <<<"$profile_json"
	)
	oauth_token=$(
		jq -cer '
			.oauth_token
			| if (.access_token // "") == "" then
				error("profile is missing oauth_token.access_token")
			else
				.
			end
		' <<<"$profile_json"
	)

	"$raycast_node" "$user_defaults_bridge" "$app_support" "$raycast_key" "$beta_data_node" "$current_user" "$oauth_token"
}

if [[ $(uname -s) != Darwin ]]; then
	log 'not running on macOS; skipping'
	exit 0
fi

require_command curl jq killall mktemp open sed sips sort tail yq

beta_app='/Applications/Raycast Beta.app'
beta_bundle="$beta_app/Contents/Resources/macos-app_RaycastDesktopApp.bundle/Contents/Resources"
beta_data_node="$beta_bundle/backend/data.darwin-arm64.node"
app_support=${RAYCAST_APP_SUPPORT:-"$HOME/Library/Application Support/com.raycast-x.macos"}
profile_dir=${RAYCAST_PROFILE_DIR:-"$HOME/.config/raycast"}
profile_file=${RAYCAST_PROFILE_FILE:-"$profile_dir/profile.toml"}
keydump_hook_source=${RAYCAST_KEYDUMP_HOOK:-"$profile_dir/keydump.cjs"}
user_defaults_bridge=${RAYCAST_USER_DEFAULTS_BRIDGE:-"$profile_dir/bridge.cjs"}
avatar_path=$app_support/avatar.png
key_capture_retries=30
key_capture_interval=1
raycast_key=
raycast_node=

if [[ ! -d $beta_app ]]; then
	warn 'Raycast Beta not found; skipping Raycast Beta user patch'
	exit 0
fi
if [[ ! -f $beta_data_node ]]; then
	warn "Raycast Beta data addon not found; skipping Raycast Beta user patch: $beta_data_node"
	exit 0
fi
require_file "$profile_file"
require_file "$keydump_hook_source"
require_file "$user_defaults_bridge"

extract_key
ensure_avatar
write_user_defaults
log 'starting Raycast Beta'
open_beta
log 'Raycast Beta started'
