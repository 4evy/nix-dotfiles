#!/usr/bin/env bash
# shellcheck shell=bash
## usage: gnome-catppuccin-accent [--once|--watch]
{{ $ctp := include ".chezmoitemplates/catppuccin_palette.json" | fromJson -}}
{{ $latte := index $ctp "latte" -}}
{{ $frappe := index $ctp "frappe" -}}
set -euo pipefail

readonly LATTE_PINK="{{ index $latte "pink" }}"
readonly FRAPPE_PINK="{{ index $frappe "pink" }}"
readonly ACCENT_FG_GTK="rgba(0, 0, 0, 0.8)"
readonly ACCENT_FG_VAR="rgb(0 0 0 / 80%)"

config_home() {
	printf '%s\n' "${XDG_CONFIG_HOME:-$HOME/.config}"
}

require_command() {
	local command_name

	for command_name in "$@"; do
		if ! command -v "$command_name" >/dev/null 2>&1; then
			printf 'gnome-catppuccin-accent: required command is not available: %s\n' "$command_name" >&2
			exit 1
		fi
	done
}

have_gnome_interface_schema() {
	command -v gsettings >/dev/null 2>&1 &&
		gsettings list-schemas 2>/dev/null | grep -Fxq 'org.gnome.desktop.interface'
}

current_accent() {
	local scheme

	if have_gnome_interface_schema; then
		scheme=$(gsettings get org.gnome.desktop.interface color-scheme 2>/dev/null || printf "'default'")
	else
		scheme="'default'"
	fi

	case "${scheme//\'/}" in
		prefer-dark)
			printf '%s\n' "$FRAPPE_PINK"
			;;
		*)
			printf '%s\n' "$LATTE_PINK"
			;;
	esac
}

write_if_changed() {
	local path=$1
	local content=$2
	local dir
	local tmp

	dir=${path%/*}
	[[ $dir != "$path" ]] || dir=.
	install -d -m 0755 -- "$dir"

	tmp=$(mktemp "$dir/.${path##*/}.XXXXXX")
	if ! printf '%s' "$content" >"$tmp"; then
		rm -f -- "$tmp"
		return 1
	fi

	if [[ -f $path ]] && cmp -s -- "$tmp" "$path"; then
		rm -f -- "$tmp"
		return 0
	fi

	if ! mv -f -- "$tmp" "$path"; then
		rm -f -- "$tmp"
		return 1
	fi
}

set_native_gnome_accent() {
	if ! have_gnome_interface_schema; then
		return 0
	fi

	if gsettings range org.gnome.desktop.interface accent-color 2>/dev/null | grep -Fq "'pink'"; then
		gsettings set org.gnome.desktop.interface accent-color 'pink' >/dev/null 2>&1 || true
	fi
}

apply_accent() {
	local accent
	local cfg
	local gtk3_css
	local gtk4_css

	accent=$(current_accent)
	cfg=$(config_home)

	gtk3_css="/* Generated by gnome-catppuccin-accent. */
@define-color accent_color ${accent};
@define-color accent_bg_color ${accent};
@define-color accent_fg_color ${ACCENT_FG_GTK};
@define-color theme_selected_bg_color ${accent};
@define-color theme_selected_fg_color ${ACCENT_FG_GTK};
@define-color theme_unfocused_selected_bg_color ${accent};
@define-color theme_unfocused_selected_fg_color ${ACCENT_FG_GTK};
"

	gtk4_css="/* Generated by gnome-catppuccin-accent. */
@define-color accent_color ${accent};
@define-color accent_bg_color ${accent};
@define-color accent_fg_color ${ACCENT_FG_GTK};

:root {
  --accent-bg-color: ${accent};
  --accent-fg-color: ${ACCENT_FG_VAR};
  --accent-color: oklab(from var(--accent-bg-color) var(--standalone-color-oklab));
}
"

	write_if_changed "$cfg/gtk-3.0/catppuccin-accent.css" "$gtk3_css"
	write_if_changed "$cfg/gtk-4.0/catppuccin-accent.css" "$gtk4_css"
	set_native_gnome_accent
}

watch_accent() {
	apply_accent

	if ! have_gnome_interface_schema; then
		return 0
	fi

	gsettings monitor org.gnome.desktop.interface color-scheme |
		while IFS= read -r _; do
			apply_accent
		done
}

case "${1:---once}" in
	--once)
		require_command cmp install mktemp mv rm
		apply_accent
		;;
	--watch)
		require_command cmp install mktemp mv rm
		watch_accent
		;;
	*)
		sed -n 's/^##[[:space:]]\{0,1\}//p' "${BASH_SOURCE[0]}" >&2
		exit 2
		;;
esac
