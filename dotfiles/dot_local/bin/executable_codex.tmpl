#!/usr/bin/env bash
# shellcheck shell=bash
set -euo pipefail

readonly HOME_DIR={{ .chezmoi.homeDir | quote }}

find_real_codex() {
	local candidate
	for candidate in \
		"${CODEX_REAL_BIN:-}" \
		"${HOME_DIR}/.bun/bin/codex" \
		"${HOME_DIR}/.cache/.bun/bin/codex" \
		"${HOME_DIR}/.npm/bin/codex" \
		"${HOME_DIR}/.bun/install/global/node_modules/.bin/codex" \
		/opt/homebrew/bin/codex \
		/usr/local/bin/codex \
		/usr/bin/codex; do
		[[ -n "${candidate}" && -x "${candidate}" ]] || continue
		[[ "${candidate}" != "${BASH_SOURCE[0]}" ]] || continue
		printf '%s\n' "${candidate}"
		return 0
	done
	return 1
}

real_codex="$(find_real_codex)" || {
	printf 'codex: real Codex binary not found\n' >&2
	exit 127
}

runner_args=("$@")
if [[ -z "${ZELLIJ_THEME_RUN_CODEX_BIN:-}" ]]; then
	for index in "${!runner_args[@]}"; do
		if [[ "${runner_args[$index]}" == "--dangerously-bypass-approvals-and-sandbox" ]]; then
			unset 'runner_args[index]'
		fi
	done
fi

if [[ -x "${HOME_DIR}/.local/bin/zellij-theme-run" ]]; then
	export ZELLIJ_THEME_RUN_CODEX_BIN="${real_codex}"
	export ZELLIJ_THEME_RUN_CODEX_WRAPPER="${BASH_SOURCE[0]}"
	exec "${HOME_DIR}/.local/bin/zellij-theme-run" codex "${runner_args[@]}"
fi

if zellij_theme_run="$(command -v zellij-theme-run 2>/dev/null)" && [[ -x "${zellij_theme_run}" ]]; then
	export ZELLIJ_THEME_RUN_CODEX_BIN="${real_codex}"
	export ZELLIJ_THEME_RUN_CODEX_WRAPPER="${BASH_SOURCE[0]}"
	exec "${zellij_theme_run}" codex "${runner_args[@]}"
fi

exec "${real_codex}" "$@"
