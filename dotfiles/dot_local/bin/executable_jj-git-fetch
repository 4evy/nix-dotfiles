#!/usr/bin/env bash
set -euo pipefail

state_file="${JJ_GIT_FETCH_SHIM_STATE:-}"

write_state() {
	if [[ -n "$state_file" ]]; then
		printf '%s\n' "$1" >"$state_file"
	fi
}

delegate() {
	write_state delegate
	exit 0
}

handled() {
	write_state handled
}

write_state delegate

if [[ "${JJ_GIT_FETCH_SHALLOW_SHIM:-1}" == 0 ]]; then
	delegate
fi

if [[ "${1:-}" != git || "${2:-}" != fetch ]]; then
	delegate
fi
shift 2

if ! git rev-parse --git-dir >/dev/null 2>&1; then
	delegate
fi

if [[ "$(git rev-parse --is-shallow-repository 2>/dev/null)" != true ]]; then
	delegate
fi

depth="${JJ_GIT_FETCH_DEPTH:-1}"
remotes=()
branches=()
all_remotes=false
explicit_branches=false

while (($#)); do
	case "$1" in
		--remote)
			shift
			(($#)) || delegate
			remotes+=("$1")
			;;
		--remote=*)
			remotes+=("${1#--remote=}")
			;;
		-b | --branch | --bookmark)
			shift
			(($#)) || delegate
			branches+=("$1")
			explicit_branches=true
			;;
		--branch=* | --bookmark=*)
			branches+=("${1#*=}")
			explicit_branches=true
			;;
		--all-remotes)
			all_remotes=true
			;;
		--tracked | --tag | --tag=* | -t | -h | --help)
			delegate
			;;
		*)
			delegate
			;;
	esac
	shift
done

if $all_remotes && ((${#remotes[@]})); then
	delegate
fi

if $all_remotes; then
	mapfile -t remotes < <(git remote)
elif ((${#remotes[@]} == 0)); then
	mapfile -t remotes < <(git remote)
	if ((${#remotes[@]} != 1)); then
		if git remote get-url origin >/dev/null 2>&1; then
			remotes=(origin)
		else
			delegate
		fi
	fi
fi

for remote in "${remotes[@]}"; do
	case "$remote" in
		*'*'* | *'?'* | *'|'* | *'~'* | *'('* | *')'*)
			delegate
			;;
	esac
done

for branch in "${branches[@]}"; do
	case "$branch" in
		*'*'* | *'?'* | *'|'* | *'~'* | *'('* | *')'*)
			delegate
			;;
	esac
done

handled
for remote in "${remotes[@]}"; do
	refspecs=()
	tag_args=()
	if ((${#branches[@]})); then
		for branch in "${branches[@]}"; do
			refspecs+=("+refs/heads/${branch}:refs/remotes/${remote}/${branch}")
		done
	else
		mapfile -t refspecs < <(git config --get-all "remote.${remote}.fetch" || true)
		if ((${#refspecs[@]} == 0)); then
			refspecs=("+refs/heads/*:refs/remotes/${remote}/*")
		fi
	fi
	if $explicit_branches; then
		tag_args=(--no-tags)
	fi

	git fetch --depth="$depth" --prune --no-write-fetch-head --verbose --progress "${tag_args[@]}" -- "$remote" "${refspecs[@]}"
done

jj git import
