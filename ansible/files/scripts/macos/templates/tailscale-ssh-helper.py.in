#!/usr/bin/env python3
from __future__ import annotations

import subprocess
import time


def main() -> int:
    for _ in range(30):
        result = subprocess.run(
            ("@prerequisites_tailscale_bin@", "set", "--ssh=true"),
            check=False,
        )
        if result.returncode == 0:
            return 0
        time.sleep(2)
    return 1


if __name__ == "__main__":
    raise SystemExit(main())
