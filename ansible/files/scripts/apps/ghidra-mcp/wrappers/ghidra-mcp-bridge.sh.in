#!/usr/bin/env bash
# shellcheck shell=bash
set -euo pipefail

default_install_root=@INSTALL_ROOT@

: "${GHIDRA_MCP_BIND_ADDRESS:=127.0.0.1}"
: "${GHIDRA_MCP_PORT:=8089}"
: "${GHIDRA_DEBUGGER_URL:=http://127.0.0.1:8099}"
: "${GHIDRA_MCP_BRIDGE_HOST:=127.0.0.1}"
: "${GHIDRA_MCP_BRIDGE_PORT:=8090}"
: "${GHIDRA_MCP_BRIDGE_TRANSPORT:=stdio}"
: "${GHIDRA_MCP_CONNECT_HOST:=127.0.0.1}"

export PYTHONDONTWRITEBYTECODE=1
export PYTHONNOUSERSITE=1
export GHIDRA_MCP_STATE="${GHIDRA_MCP_STATE:-$HOME/.local/state/ghidra-mcp-headless}"
export GHIDRA_MCP_BIND="${GHIDRA_MCP_BIND:-$GHIDRA_MCP_BIND_ADDRESS}"
export GHIDRA_MCP_URL="${GHIDRA_MCP_URL:-http://$GHIDRA_MCP_CONNECT_HOST:$GHIDRA_MCP_PORT}"
mkdir -p "$GHIDRA_MCP_STATE/tmp" "$GHIDRA_MCP_STATE/runtime"
chmod 700 "$GHIDRA_MCP_STATE/runtime"
export TMPDIR="${TMPDIR:-$GHIDRA_MCP_STATE/tmp}"
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-$GHIDRA_MCP_STATE/runtime}"

case " $* " in
	*" --help "* | *" -h "*) GHIDRA_MCP_SKIP_WAIT=1 ;;
esac

if [[ ${GHIDRA_MCP_SKIP_WAIT:-0} != 1 ]]; then
	timeout=${GHIDRA_MCP_WAIT_TIMEOUT_SEC:-1800}
	deadline=$((SECONDS + timeout))
	until curl -fsS "$GHIDRA_MCP_URL/check_connection" >/dev/null 2>&1; do
		if ((SECONDS >= deadline)); then
			printf 'error: timed out waiting for %s/check_connection\n' "$GHIDRA_MCP_URL" >&2
			exit 1
		fi
		sleep 1
	done
fi

exec "$default_install_root/venv/bin/python" -m bridge_mcp_ghidra \
	--transport "$GHIDRA_MCP_BRIDGE_TRANSPORT" \
	--mcp-host "$GHIDRA_MCP_BRIDGE_HOST" \
	--mcp-port "$GHIDRA_MCP_BRIDGE_PORT" \
	--no-lazy \
	"$@"
