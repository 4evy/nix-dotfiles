#!/usr/bin/env python3
from __future__ import annotations

import os
import shlex
from pathlib import Path

INSTALL_ROOT = Path(@INSTALL_ROOT@)
DEFAULT_GHIDRA_HOME = Path(@GHIDRA_HOME@)
JAR_VERSION = @JAR_VERSION@


def main() -> None:
    environment = dict(os.environ)
    bind = environment.setdefault("GHIDRA_MCP_BIND_ADDRESS", "127.0.0.1")
    port = environment.setdefault("GHIDRA_MCP_PORT", "8089")
    environment.setdefault("GHIDRA_MCP_ALLOW_SCRIPTS", "")
    environment.setdefault("GHIDRA_MCP_AUTH_TOKEN", "")
    environment.setdefault("GHIDRA_MCP_ARCHIVE_URL", "")
    environment.setdefault("GHIDRA_MCP_FILE_ROOT", "")
    environment.setdefault("GHIDRA_MCP_PROJECT_FOLDER", "")
    ghidra_home = Path(environment.setdefault("GHIDRA_HOME", os.fspath(DEFAULT_GHIDRA_HOME)))
    state = Path(
        environment.setdefault(
            "GHIDRA_MCP_STATE",
            os.fspath(Path.home() / ".local/state/ghidra-mcp-headless"),
        )
    )
    environment.setdefault("GHIDRA_MCP_BIND", bind)
    for name in ("home", "tmp", "runtime"):
        (state / name).mkdir(parents=True, exist_ok=True)
    (state / "runtime").chmod(0o700)
    environment["TMPDIR"] = os.fspath(state / "tmp")
    environment.setdefault("XDG_RUNTIME_DIR", os.fspath(state / "runtime"))
    environment["HOME"] = os.fspath(state / "home")
    jars = [INSTALL_ROOT / f"share/java/GhidraMCP-{JAR_VERSION}.jar"]
    for root in ("Debug", "Features", "Framework", "Processors"):
        directory = ghidra_home / "Ghidra" / root
        if directory.is_dir():
            jars.extend(path for path in directory.rglob("*.jar") if path.parent.name == "lib")
    java = (
        Path(environment["JAVA_HOME"]) / "bin/java"
        if environment.get("JAVA_HOME")
        else Path("java")
    )
    arguments = shlex.split(environment.get("JAVA_OPTS", ""))
    if environment.get("GHIDRA_USER"):
        arguments.append(f"-Duser.name={environment['GHIDRA_USER']}")
    arguments.extend(
        (
            f"-Duser.home={state / 'home'}",
            f"-Djava.io.tmpdir={state / 'tmp'}",
            f"-Dghidra.home={ghidra_home}",
            "-Dapplication.name=GhidraMCP",
            "-classpath",
            os.pathsep.join(os.fspath(path) for path in jars),
            "com.xebyte.headless.GhidraMCPHeadlessServer",
            "--bind",
            environment["GHIDRA_MCP_BIND"],
            "--port",
            port,
        )
    )
    for variable, option in (
        ("PROGRAM_FILE", "--file"),
        ("PROJECT_PATH", "--project"),
        ("PROGRAM_NAME", "--program"),
    ):
        if environment.get(variable):
            arguments.extend((option, environment[variable]))
    arguments.extend(shlex.split(environment.get("GHIDRA_MCP_EXTRA_ARGS", "")))
    os.execvpe(java, (java, *arguments), environment)


if __name__ == "__main__":
    main()
