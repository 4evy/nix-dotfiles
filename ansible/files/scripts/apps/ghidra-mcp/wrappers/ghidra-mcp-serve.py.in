#!/usr/bin/env python3
from __future__ import annotations

import os
import subprocess
from pathlib import Path

INSTALL_ROOT = Path(@INSTALL_ROOT@)


def main() -> int:
    environment = dict(os.environ)
    bind = environment.setdefault("GHIDRA_MCP_BIND", "127.0.0.1")
    port = environment.setdefault("GHIDRA_MCP_PORT", "8089")
    environment.setdefault("GHIDRA_MCP_BRIDGE_HOST", "127.0.0.1")
    environment.setdefault("GHIDRA_MCP_BRIDGE_PORT", "8090")
    environment.setdefault("GHIDRA_MCP_BRIDGE_TRANSPORT", "streamable-http")
    environment.setdefault("GHIDRA_MCP_ALLOW_SCRIPTS", "1")
    environment.setdefault("GHIDRA_MCP_URL", f"http://{bind}:{port}")
    environment.setdefault(
        "GHIDRA_MCP_STATE",
        os.fspath(
            Path(environment.get("XDG_STATE_HOME", Path.home() / ".local/state"))
            / "ghidra-mcp-headless"
        ),
    )
    Path(environment["GHIDRA_MCP_STATE"]).mkdir(parents=True, exist_ok=True)
    httpd = subprocess.Popen((INSTALL_ROOT / "bin/ghidra-mcp-httpd",), env=environment)
    try:
        return subprocess.run(
            (INSTALL_ROOT / "bin/ghidra-mcp-bridge",), env=environment, check=False
        ).returncode
    finally:
        httpd.terminate()
        try:
            httpd.wait(timeout=5)
        except subprocess.TimeoutExpired:
            httpd.kill()


if __name__ == "__main__":
    raise SystemExit(main())
