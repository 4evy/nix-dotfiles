#!/usr/bin/env python3
from __future__ import annotations

import os
import sys
import time
import urllib.error
import urllib.request
from pathlib import Path

INSTALL_ROOT = Path(@INSTALL_ROOT@)


def main() -> None:
    environment = dict(os.environ)
    bind = environment.setdefault("GHIDRA_MCP_BIND_ADDRESS", "127.0.0.1")
    port = environment.setdefault("GHIDRA_MCP_PORT", "8089")
    environment.setdefault("GHIDRA_DEBUGGER_URL", "http://127.0.0.1:8099")
    bridge_host = environment.setdefault("GHIDRA_MCP_BRIDGE_HOST", "127.0.0.1")
    bridge_port = environment.setdefault("GHIDRA_MCP_BRIDGE_PORT", "8090")
    transport = environment.setdefault("GHIDRA_MCP_BRIDGE_TRANSPORT", "stdio")
    connect_host = environment.setdefault("GHIDRA_MCP_CONNECT_HOST", "127.0.0.1")
    environment["PYTHONDONTWRITEBYTECODE"] = "1"
    environment["PYTHONNOUSERSITE"] = "1"
    state = Path(
        environment.setdefault(
            "GHIDRA_MCP_STATE",
            os.fspath(Path.home() / ".local/state/ghidra-mcp-headless"),
        )
    )
    (state / "tmp").mkdir(parents=True, exist_ok=True)
    runtime = state / "runtime"
    runtime.mkdir(parents=True, exist_ok=True, mode=0o700)
    runtime.chmod(0o700)
    environment.setdefault("GHIDRA_MCP_BIND", bind)
    url = environment.setdefault("GHIDRA_MCP_URL", f"http://{connect_host}:{port}")
    environment.setdefault("TMPDIR", os.fspath(state / "tmp"))
    environment.setdefault("XDG_RUNTIME_DIR", os.fspath(runtime))
    help_requested = any(argument in {"-h", "--help"} for argument in sys.argv[1:])
    if environment.get("GHIDRA_MCP_SKIP_WAIT", "0") != "1" and not help_requested:
        deadline = time.monotonic() + int(environment.get("GHIDRA_MCP_WAIT_TIMEOUT_SEC", "1800"))
        while True:
            try:
                with urllib.request.urlopen(f"{url}/check_connection", timeout=5):
                    break
            except (urllib.error.URLError, TimeoutError):
                if time.monotonic() >= deadline:
                    raise SystemExit(f"error: timed out waiting for {url}/check_connection")
                time.sleep(1)
    python = INSTALL_ROOT / "venv/bin/python"
    os.execve(
        python,
        (
            python,
            "-m",
            "bridge_mcp_ghidra",
            "--transport",
            transport,
            "--mcp-host",
            bridge_host,
            "--mcp-port",
            bridge_port,
            "--no-lazy",
            *sys.argv[1:],
        ),
        environment,
    )


if __name__ == "__main__":
    main()
