# Start from an empty build context and add back only the paths used by the
# smoke-test Dockerfile and Spectrum image builds.
*

!Dockerfile
!.dockerignore
!.ansible-lint
!.yamllint
!ansible.cfg
!go.mod
!go.sum
!pyproject.toml
!uv.lock

!cmd/
!cmd/chezmoi-support/
!cmd/chezmoi-support/**
!internal/
!internal/**

!containers/
!containers/**

!ansible/
!ansible/**

!dotfiles/
!dotfiles/**

!spectrum/
!spectrum/**

!packages/
packages/*
!packages/scripts/
!packages/scripts/**

# Never send local generated state if it appears under an included path.
**/.DS_Store
**/__pycache__/
**/*.pyc
**/target/
.docker-cache/
.git/
*.log
